# Zer0Talk .gitignore
# Based on the standard .NET template with project-specific additions.

# Build output
AI/
AI/Archived/
publish/
bin/
obj/
**/bin/
**/obj/
[Bb]uild/
[Bb]uildOutput/
_trash/

# Installer and Uninstaller (not tracked in repo)
Uninstaller/
Zer0Talk.Installer/bin/
Zer0Talk.Installer/obj/
*.msi
*.wixpdb

# Scripts folder - development/build scripts not needed in repo
scripts/


# Publish artifacts
publish/
*.Publish.xml
*.pubxml
*.pubxml.user
*.publishsettings
*.pubxml*.user
*.publish.log
*.zip
checkpoint*
publish/**/*.zip
publish/**/*.dll
publish/**/*.json

# Logs and diagnostics
logs/
**/logs/
*.log
*.etl
*.dmp
error.txt

# User- and IDE-specific files
.vs/
.vscode/
.idea/
.idea/**
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.DotSettings
*.sln.DotSettings
*.DotSettings.user

# Generated caches / databases
*.db
*.db-shm
*.db-wal
*.pdb
*.mdb
*.ldf
*.mdf
*.log.db

# Temporary files and folders
*.tmp
*.temp
~$*
*.bak
*_tmp/
.tmp/
cache/
_tmp/
_trash/
tmp/
/tmp/
*.old
*.orig
*.swp
*.swn
tmp_*
*.pid

# Secrets and certificates
*.pfx
*.snk
*.key
*.cer
*.p12
*.pem
*.p7b
*.p7s
secret*/
*.p2e

# Sensitive encryption source
Services/EncryptionService.cs
Services/EncryptionService.*

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/
*.lnk
!Assets/Icons/Icon.ico

# Package artifacts
*.nupkg
*.snupkg
*.symbols.nupkg

# Image assets
*.png
*.ico
!Assets/Avatars/*.png
!Assets/Icons/**/*.ico

# Tooling state
**/node_modules/
.yarn/
.pnpm-store/

# PowerShell history and cache
*.ps1xml
*.psc1
powershell_history.txt
*.ps1
# But allow specific installer build scripts
!Zer0Talk.Installer/build-installer.ps1

# Miscellaneous
*.iws
*.tlog
*.psess
*.vsp
*.vspx
*.vspscc
*.vssscc
*.cache
*.sdf
*.opensdf
*.ipch
*.dbmdl
*.jfm
*.vgdbsettings
workspace.xml
lint-report.json
Suggestions.md
context.md

# Temporary build/share docs that should not be committed
RELEASE-DEBUG-SC.md
Release-Description.md
temp_pending_invites.txt

# Documentation drafts stay local only
# Note: track only specific user-facing docs; ignore other markdown files in docs/
# Allow the docs directory itself
!docs/
# Ignore all markdown in docs but allow specific files below
docs/*.md
!docs/user-guide.md
!docs/THEME-EDITOR-USER-GUIDE.md

checklist.md

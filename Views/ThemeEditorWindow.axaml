<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Zer0Talk.ViewModels"
    xmlns:cp="using:Zer0Talk.Controls.ColorPicker"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Zer0Talk.Views.ThemeEditorWindow"
        x:DataType="vm:ThemeEditorViewModel"
        Title="{Binding LocalizedThemeEditorTitle}"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="32">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Custom Title Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar with Drag Area -->
        <Border Grid.Row="0" Background="{DynamicResource App.TitleBarBackground}" BorderBrush="{DynamicResource App.Border}" BorderThickness="0,0,0,1" Padding="6">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Draggable Title Area -->
                <Border Grid.Column="0" Background="Transparent" PointerPressed="OnTitleBarPointerPressed">
                    <StackPanel Orientation="Horizontal" Margin="6,0" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="🎨" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource App.TitleBarForeground}"/>
                        <TextBlock Text="{Binding LocalizedThemeEditorTitle}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource App.TitleBarForeground}"/>
                    </StackPanel>
                </Border>
                
                <!-- Window Control Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedMinimize}" Click="OnMinimizeClick">
                        <TextBlock Classes="icon-mdl2" Text="&#xE921;"/>
                    </Button>
                    <Button x:Name="ThemeEditorMaximizeRestoreButton" Classes="icon-button" ToolTip.Tip="{Binding LocalizedMaximize}" Click="OnMaximizeClick">
                        <TextBlock x:Name="ThemeEditorMaximizeRestoreIcon" Classes="icon-mdl2" Text="&#xE922;"/>
                    </Button>
                    <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedClose}" Click="OnCloseClick">
                        <TextBlock Classes="icon-mdl2" Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource App.Surface}" 
            BorderBrush="{DynamicResource App.Border}" BorderThickness="0,0,0,1" Padding="4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <!-- 32px gap spacer -->
                <Border Width="32" Height="32"/>
                
                <!-- Undo/Redo -->
                <Button Command="{Binding UndoColorEditCommand}" 
                    Background="{DynamicResource App.ButtonBackground}"
                        IsEnabled="{Binding CanUndo}"
                        Width="32" Height="32" Padding="4" CornerRadius="4" ToolTip.Tip="{Binding LocalizedUndo}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12.5,8C9.85,8 7.45,9 5.6,10.6L2,7V16H11L7.38,12.38C8.77,11.22 10.54,10.5 12.5,10.5C16.04,10.5 19.05,12.81 20.1,16L22.47,15.22C21.08,11.03 17.15,8 12.5,8Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Command="{Binding RedoColorEditCommand}" 
                    Background="{DynamicResource App.ButtonBackground}"
                        IsEnabled="{Binding CanRedo}"
                        Width="32" Height="32" Padding="4" CornerRadius="4" ToolTip.Tip="{Binding LocalizedRedo}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Data="M18.4,10.6C16.55,8.99 14.15,8 11.5,8C6.85,8 2.92,11.03 1.54,15.22L3.9,16C4.95,12.81 7.95,10.5 11.5,10.5C13.45,10.5 15.23,11.22 16.62,12.38L13,16H22V7L18.4,10.6Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Command="{Binding ToggleHistoryPanelCommand}" 
                    Background="{DynamicResource App.ButtonBackground}"
                        Width="32" Height="32" Padding="4" CornerRadius="4" ToolTip.Tip="{Binding LocalizedHistory}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3A9,9 0 0,0 4,12H1L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3" Fill="{DynamicResource App.ForegroundPrimary}"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Left Sidebar -->
                <ColumnDefinition Width="2*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar: Action Buttons -->
            <Border Grid.Column="0" Background="{DynamicResource App.Surface}" 
                    BorderBrush="{DynamicResource App.Border}" BorderThickness="0,0,1,0" 
                    Padding="4" Width="40">
                <StackPanel Spacing="4" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <!-- New Blank Theme -->
                    <Button Command="{Binding NewFromBlankTemplateCommand}" 
                            Background="{DynamicResource App.ButtonBackground}"
                            Width="32" Height="32" Padding="4" CornerRadius="4"
                            ToolTip.Tip="{Binding LocalizedNewTheme}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Open Theme -->
                    <Button Command="{Binding ImportThemeCommand}" 
                            Background="{DynamicResource App.ButtonBackground}"
                            Width="32" Height="32" Padding="4" CornerRadius="4"
                            ToolTip.Tip="{Binding LocalizedOpenTheme}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>



                    <!-- Save -->
                    <Button Command="{Binding SaveCommand}" 
                            Background="{DynamicResource App.ButtonBackground}"
                            Width="32" Height="32" Padding="4" CornerRadius="4"
                            ToolTip.Tip="{Binding LocalizedSaveTheme}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Save As -->
                    <Button Command="{Binding SaveAsCommand}" 
                            Background="{DynamicResource App.ButtonBackground}"
                            Width="32" Height="32" Padding="4" CornerRadius="4"
                            ToolTip.Tip="{Binding LocalizedSaveThemeAs}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Data="M14,17H17V14H19V17H22V19H19V22H17V19H14V17M12,17V19H5V5H15V12H17V5C17,3.89 16.1,3 15,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H12.4C12.14,20.36 12,19.69 12,19C12,18.3 12.14,17.64 12.4,17H12Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Search for Themes -->
                    <Button Command="{Binding SearchDrivesForThemesCommand}" 
                            Background="{DynamicResource App.ButtonBackground}"
                            Width="32" Height="32" Padding="4" CornerRadius="4"
                            ToolTip.Tip="{Binding LocalizedSearchThemes}">
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Center Panel: Colors and Gradients -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20" Margin="10">
                    
                    <!-- Theme Metadata Section -->
                            <Border Background="{DynamicResource App.Surface}" 
                                BorderBrush="{DynamicResource App.Border}" 
                                BorderThickness="1" CornerRadius="6" Padding="15"
                                HorizontalAlignment="Left" MaxWidth="650">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding LocalizedThemeMetadata}" FontSize="16" FontWeight="Bold"/>
                            
                            <Grid ColumnDefinitions="Auto,400" RowDefinitions="Auto,Auto,Auto,Auto" 
                                  VerticalAlignment="Top" HorizontalAlignment="Left">
                                <Grid.Styles>
                                    <Style Selector="TextBlock.label">
                                        <Setter Property="Margin" Value="0,0,10,5"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style Selector="TextBox">
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                    </Style>
                                </Grid.Styles>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedNameLabel}" Classes="label"/>
                                <TextBox Grid.Row="0" Grid.Column="1" 
                                         Text="{Binding EditableThemeName}" 
                                         IsEnabled="{Binding IsEditingMetadata}"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedAuthorLabel}" Classes="label"/>
                                <TextBox Grid.Row="1" Grid.Column="1" 
                                         Text="{Binding EditableThemeAuthor}" 
                                         IsEnabled="{Binding IsEditingMetadata}"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LocalizedVersionLabel}" Classes="label"/>
                                <TextBox Grid.Row="2" Grid.Column="1" 
                                         Text="{Binding EditableThemeVersion}" 
                                         IsEnabled="{Binding IsEditingMetadata}"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding LocalizedDescriptionLabel}" Classes="label"/>
                                <TextBox Grid.Row="3" Grid.Column="1" 
                                         Text="{Binding EditableThemeDescription}" 
                                         IsEnabled="{Binding IsEditingMetadata}"
                                         AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>
                            </Grid>
                            
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                <Button Content="{Binding LocalizedEditMetadata}" 
                                    Command="{Binding EditMetadataCommand}"
                                    IsVisible="{Binding !IsEditingMetadata}"
                                    Background="{DynamicResource App.ButtonBackground}"
                                    Padding="10,5" CornerRadius="4"/>
                                <Button Content="{Binding LocalizedSave}" 
                                    Command="{Binding SaveMetadataCommand}"
                                    IsVisible="{Binding IsEditingMetadata}"
                                    Background="{DynamicResource App.ButtonBackground}"
                                    Padding="10,5" CornerRadius="4"/>
                                <Button Content="{Binding LocalizedCancel}" 
                                    Command="{Binding CancelMetadataEditCommand}"
                                    IsVisible="{Binding IsEditingMetadata}"
                                    Background="{DynamicResource App.ButtonBackground}"
                                    Padding="10,5" CornerRadius="4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- System Accent Color Overrides Section -->
                    <Border Background="{DynamicResource App.Surface}" 
                            BorderBrush="{DynamicResource App.Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel Spacing="15">
                            <Grid ColumnDefinitions="*,Auto" PointerPressed="SystemAccentHeader_PointerPressed" Cursor="Hand">
                                <TextBlock Grid.Column="0" Text="{Binding LocalizedSystemAccentOverrides}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="SystemAccentToggle" Text="▼" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            </Grid>
                            <StackPanel x:Name="SystemAccentContent" Spacing="15">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding LocalizedSystemAccentDescription1}" 
                                               FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding LocalizedSystemAccentDescription2}" 
                                               FontSize="11" Opacity="0.6" TextWrapping="Wrap" FontStyle="Italic"/>
                                </StackPanel>
                            
                            <Grid ColumnDefinitions="Auto,200,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" 
                                  VerticalAlignment="Top" HorizontalAlignment="Left">
                                <Grid.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                    </Style>
                                    <Style Selector="TextBox">
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                    </Style>
                                    <Style Selector="Border">
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                    </Style>
                                    <Style Selector="Button">
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                    </Style>
                                </Grid.Styles>
                                <!-- SystemAccentColor -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedPrimaryAccent}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SystemAccentColor}" 
                                         Watermark="#0078D4" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="0" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemAccentColor_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemAccentColorPreview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="0" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemAccentColorCommand}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"
                                    ToolTip.Tip="{Binding LocalizedClearToUseOsColor}"/>
                                
                                <!-- SystemAccentColor2 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedSecondaryAccent}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SystemAccentColor2}" 
                                         Watermark="#005A9E" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="1" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemAccentColor2_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemAccentColor2Preview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="1" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemAccentColor2Command}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"
                                    ToolTip.Tip="{Binding LocalizedClearToUseOsColor}"/>
                                
                                <!-- SystemAccentColor3 -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LocalizedTertiaryAccent}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SystemAccentColor3}" 
                                         Watermark="#106EBE" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="2" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemAccentColor3_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemAccentColor3Preview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="2" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemAccentColor3Command}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"
                                    ToolTip.Tip="{Binding LocalizedClearToUseOsColor}"/>
                                
                                <!-- SystemAccentColor4 -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding LocalizedQuaternaryAccent}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SystemAccentColor4}" 
                                         Watermark="#0086F0" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="3" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemAccentColor4_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemAccentColor4Preview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="3" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemAccentColor4Command}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"
                                    ToolTip.Tip="{Binding LocalizedClearToUseOsColor}"/>
                                
                                <!-- SystemAccentColorLight -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding LocalizedHoverAccent}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SystemAccentColorLight}" 
                                         Watermark="#60CDFF" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="4" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemAccentColorLight_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemAccentColorLightPreview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="4" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemAccentColorLightCommand}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"
                                    ToolTip.Tip="{Binding LocalizedClearToUseOsColor}"/>

                                <!-- SystemListLowColor -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding LocalizedSubtleHover}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SystemListLowColor}" 
                                         Watermark="#33FFFFFF" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="5" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemListLowColor_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemListLowColorPreview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="5" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemListLowColorCommand}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"
                                    ToolTip.Tip="{Binding LocalizedClearToUseOsColor}"/>

                                <!-- SystemListMediumColor -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding LocalizedMediumHover}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SystemListMediumColor}" 
                                         Watermark="#66FFFFFF" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="6" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemListMediumColor_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemListMediumColorPreview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="6" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemListMediumColorCommand}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"
                                    ToolTip.Tip="{Binding LocalizedClearToUseOsColor}"/>
                            </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- System Alt Color Overrides Section -->
                    <Border Background="{DynamicResource App.Surface}" 
                            BorderBrush="{DynamicResource App.Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel Spacing="15">
                            <Grid ColumnDefinitions="*,Auto" PointerPressed="SystemAltHeader_PointerPressed" Cursor="Hand">
                                <TextBlock Grid.Column="0" Text="{Binding LocalizedSystemAltOverrides}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="SystemAltToggle" Text="▼" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            </Grid>
                            <StackPanel x:Name="SystemAltContent" Spacing="15">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding LocalizedSystemAltDescription1}" 
                                               FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding LocalizedSystemAltDescription2}" 
                                               FontSize="11" Opacity="0.6" TextWrapping="Wrap" FontStyle="Italic"/>
                                </StackPanel>
                            
                            <Grid ColumnDefinitions="Auto,200,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" 
                                  VerticalAlignment="Top" HorizontalAlignment="Left">
                                <Grid.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                    </Style>
                                    <Style Selector="TextBox">
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                    </Style>
                                    <Style Selector="Border">
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                    </Style>
                                    <Style Selector="Button">
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                    </Style>
                                </Grid.Styles>
                                <!-- SystemAltHighColor -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedAltHigh}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SystemAltHighColor}" 
                                         Watermark="#FFFFFFFF" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="0" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemAltHighColor_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemAltHighColorPreview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="0" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemAltHighColorCommand}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"
                                    ToolTip.Tip="{Binding LocalizedClearToUseOsColor}"/>
                                
                                <!-- SystemAltMediumHighColor -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedAltMediumHigh}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SystemAltMediumHighColor}" 
                                         Watermark="#CCFFFFFF" FontFamily="Consolas" FontSize="11"/>
                                <Border Grid.Row="1" Grid.Column="2" Width="40" Height="40" CornerRadius="4" 
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                        Cursor="Hand" PointerPressed="SystemAltMediumHighColor_PointerPressed"
                                        ToolTip.Tip="{Binding LocalizedClickToOpenColorPicker}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SystemAltMediumHighColorPreview}"/>
                                    </Border.Background>
                                </Border>
                                <Button Grid.Row="1" Grid.Column="3" Content="{Binding LocalizedClear}" 
                                        Command="{Binding ClearSystemAltMediumHighColorCommand}"
                                        Padding="8,4" CornerRadius="3" FontSize="11"
                                        Background="{DynamicResource App.ButtonBackground}"

                    <!-- Color Overrides Section -->
                    <Border Background="{DynamicResource App.Surface}" 
                            BorderBrush="{DynamicResource App.Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" PointerPressed="ColorOverridesHeader_PointerPressed" Cursor="Hand">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontSize="16" FontWeight="Bold" VerticalAlignment="Center">
                                        <Run Text="🎨 "/>
                                        <Run Text="{Binding LocalizedColorOverrides}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="({0} {1})">
                                                <Binding Path="ThemeColors.Count"/>
                                                <Binding Path="LocalizedColorsLabel"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="ColorOverridesToggle" Text="▼" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            </Grid>
                            <StackPanel x:Name="ColorOverridesContent" Spacing="10">
                                <TextBlock Text="{Binding LocalizedColorOverridesDescription}" 
                                           FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                
                                <ItemsControl ItemsSource="{Binding ThemeColors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="260,180,40,Auto" Margin="0,0,0,8"
                                                  VerticalAlignment="Top" HorizontalAlignment="Left">
                                                <!-- Label (Display Name) - Fixed Width -->
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" 
                                                           Margin="0,0,10,0" TextAlignment="Right"
                                                           Text="{Binding DisplayName, StringFormat='{}{0}:'}">
                                                    <ToolTip.Tip>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding ResourceKey}" FontFamily="Consolas" FontSize="11"/>
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="10" Opacity="0.7"/>
                                                        </StackPanel>
                                                    </ToolTip.Tip>
                                                </TextBlock>
                                                
                                                <!-- Color Value TextBox -->
                                                <TextBox Grid.Column="1" Text="{Binding ColorValue, Mode=TwoWay}" 
                                                         Watermark="#RRGGBB" FontFamily="Consolas" FontSize="11"
                                                         Margin="0,0,8,0"/>
                                                
                                                <!-- Color Preview (Clickable) -->
                                                <Border Grid.Column="2" Width="40" Height="32" CornerRadius="4" 
                                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PointerPressed="ColorPreview_PointerPressed"
                                                        Tag="{Binding}"
                                                        Margin="0,0,8,0"
                                                        ToolTip.Tip="{ReflectionBinding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedClickToOpenColorPicker}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding PreviewColor}"/>
                                                    </Border.Background>
                                                </Border>
                                                
                                                <!-- Clear Button -->
                                                <Button Grid.Column="3" 
                                                        Command="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).ClearColorCommand}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4" Height="32" CornerRadius="3"
                                                        Background="{DynamicResource App.ButtonBackground}"
                                                        ToolTip.Tip="{ReflectionBinding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedResetToDefault}">
                                                    <TextBlock Text="✕" FontSize="12" FontWeight="Bold"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Gradients Section -->
                        <Border Background="{DynamicResource App.Surface}" 
                            BorderBrush="{DynamicResource App.Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" PointerPressed="GradientsHeader_PointerPressed" Cursor="Hand">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontSize="16" FontWeight="Bold" VerticalAlignment="Center">
                                        <Run Text="🌈 "/>
                                        <Run Text="{Binding LocalizedGradients}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="({0} {1})">
                                                <Binding Path="ThemeGradients.Count"/>
                                                <Binding Path="LocalizedGradientsLabel"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="GradientsToggle" Text="▼" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            </Grid>
                            
                            <StackPanel x:Name="GradientsContent" Spacing="10">
                            <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ThemeGradients}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                                <Border Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" 
                                                    BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,5">
                                                <StackPanel Spacing="8" MaxWidth="800" HorizontalAlignment="Left">
                                                    <!-- Header -->
                                                    <Grid ColumnDefinitions="400,Auto">
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}" 
                                                                       FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding ResourceKey}" FontSize="9" Opacity="0.5"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                                            <Button Command="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).EditGradientCommand}"
                                                                CommandParameter="{Binding}"
                                                                IsVisible="{Binding !IsEditing}"
                                                                Padding="6,3" CornerRadius="3"
                                                                Background="{DynamicResource App.ButtonBackground}"
                                                                ToolTip.Tip="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedEditGradient}">
                                                                <Viewbox Width="14" Height="14">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Button>
                                                            <Button Command="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).SaveGradientEditCommand}"
                                                                IsVisible="{Binding IsEditing}"
                                                                Padding="6,3" CornerRadius="3"
                                                                Background="{DynamicResource App.ButtonBackground}"
                                                                ToolTip.Tip="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedSaveGradient}">
                                                                <Viewbox Width="14" Height="14">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Button>
                                                            <Button Command="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).CancelGradientEditCommand}"
                                                                IsVisible="{Binding IsEditing}"
                                                                Padding="6,3" CornerRadius="3"
                                                                Background="{DynamicResource App.ButtonBackground}"
                                                                ToolTip.Tip="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedCancelEdit}">
                                                                <Viewbox Width="14" Height="14">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="{DynamicResource App.ForegroundPrimary}"/>
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                    
                                                    <!-- Gradient Editor (when editing) -->
                                                    <StackPanel IsVisible="{Binding IsEditing}" Spacing="5">
                                                        <TextBlock Text="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedStartColorLabel}" FontSize="11"/>
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBox Grid.Column="0" Text="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).EditingGradientStartColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                     FontFamily="Consolas" FontSize="11" Margin="0,0,5,0"/>
                                                            <Border Grid.Column="1" Width="24" Height="24" CornerRadius="3" 
                                                                    BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                                                    Background="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).EditingGradientStartColor}"
                                                                    Cursor="Hand"
                                                                    PointerPressed="GradientStartColor_PointerPressed"
                                                                    Tag="{Binding}"/>
                                                        </Grid>
                                                        
                                                        <TextBlock Text="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedEndColorLabel}" FontSize="11"/>
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBox Grid.Column="0" Text="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).EditingGradientEndColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                     FontFamily="Consolas" FontSize="11" Margin="0,0,5,0"/>
                                                            <Border Grid.Column="1" Width="24" Height="24" CornerRadius="3" 
                                                                    BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                                                    Background="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).EditingGradientEndColor}"
                                                                    Cursor="Hand"
                                                                    PointerPressed="GradientEndColor_PointerPressed"
                                                                    Tag="{Binding}"/>
                                                        </Grid>
                                                        
                                                        <TextBlock Text="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedAngleLabel}" FontSize="11"/>
                                                        <TextBox Text="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).EditingGradientAngle}" 
                                                                 FontFamily="Consolas" FontSize="11"/>
                                                        
                                                        <!-- Quick Action Buttons -->
                                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                                                <Button Content="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedClearGradient}"
                                                                    Command="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).ClearGradientCommand}"
                                                                    Padding="8,4" CornerRadius="3" FontSize="11"
                                                                    ToolTip.Tip="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedClearGradientHelp}"
                                                                    Background="{DynamicResource App.ButtonBackground}"/>
                                                        </StackPanel>
                                                        
                                                        <!-- Preset Selector -->
                                                        <TextBlock Text="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).LocalizedApplyPresetLabel}" FontSize="11" Margin="0,5,0,0"/>
                                                        <ComboBox ItemsSource="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).GradientPresets}"
                                                                  SelectedItem="{Binding $parent[ItemsControl].((vm:ThemeEditorViewModel)DataContext).SelectedGradientPreset}"
                                                                  Width="200" HorizontalAlignment="Left">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                                        <TextBlock Text="{Binding Name}" Width="100"/>
                                                                        <Border Width="60" Height="20" CornerRadius="3">
                                                                            <Border.Background>
                                                                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                                                                    <GradientStop Color="{Binding StartColor}" Offset="0"/>
                                                                                    <GradientStop Color="{Binding EndColor}" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Border.Background>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    
                                                    <!-- Preview (when not editing) -->
                                                    <TextBlock IsVisible="{Binding !IsEditing}" 
                                                               Text="{Binding GradientPreview}" 
                                                               FontSize="11" FontFamily="Consolas" Opacity="0.8"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Column="2" Width="5" Background="{DynamicResource App.Border}" 
                          ResizeDirection="Columns"/>

            <!-- Right Panel: Preview and Info -->
            <ScrollViewer Grid.Column="3" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20" Margin="10">
                    
                    <!-- Current Theme Info -->
                        <Border Background="{DynamicResource App.Surface}" 
                            BorderBrush="{DynamicResource App.Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="16" FontWeight="Bold">
                                <Run Text="ℹ️ "/>
                                <Run Text="{Binding LocalizedThemeInfo}"/>
                            </TextBlock>
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="12">
                                    <Run Text="{Binding LocalizedNameLabel}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding CurrentThemeDisplayName}"/>
                                </TextBlock>
                                <TextBlock FontSize="12">
                                    <Run Text="{Binding LocalizedAuthorLabel}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding CurrentThemeAuthor}"/>
                                </TextBlock>
                                <TextBlock FontSize="12">
                                    <Run Text="{Binding LocalizedVersionLabel}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding CurrentThemeVersion}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding CurrentThemeDescription}" FontSize="11" TextWrapping="Wrap" Opacity="0.8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Edit Status -->
                        <Border Background="{DynamicResource App.Surface}" 
                            BorderBrush="{DynamicResource App.Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="16" FontWeight="Bold">
                                <Run Text="📊 "/>
                                <Run Text="{Binding LocalizedEditStatus}"/>
                            </TextBlock>
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="12">
                                    <Run Text="{Binding LocalizedCanUndoLabel}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding CanUndo}"/>
                                </TextBlock>
                                <TextBlock FontSize="12">
                                    <Run Text="{Binding LocalizedCanRedoLabel}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding CanRedo}"/>
                                </TextBlock>
                                <TextBlock FontSize="12">
                                    <Run Text="{Binding LocalizedEditingColorLabel}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding IsEditingColor}"/>
                                </TextBlock>
                                <TextBlock FontSize="12">
                                    <Run Text="{Binding LocalizedEditingGradientLabel}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding IsEditingGradient}"/>
                                </TextBlock>
                                <TextBlock FontSize="12">
                                    <Run Text="{Binding LocalizedBatchModeLabel}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding IsBatchEditMode}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Recent Colors -->
                        <Border Background="{DynamicResource App.Surface}" 
                            BorderBrush="{DynamicResource App.Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="16" FontWeight="Bold">
                                <Run Text="🕒 "/>
                                <Run Text="{Binding LocalizedRecentColors}"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding RecentColors}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="40" Height="40" CornerRadius="4" Margin="2"
                                            BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                                ToolTip.Tip="{Binding}">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding}"/>
                                            </Border.Background>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{DynamicResource App.Surface}" 
            BorderBrush="{DynamicResource App.Border}" BorderThickness="0,1,0,0" Padding="10,5">
            <TextBlock Text="{Binding LocalizedReadyStatus}" FontSize="11" Opacity="0.7"/>
        </Border>

    </Grid>
</Window>

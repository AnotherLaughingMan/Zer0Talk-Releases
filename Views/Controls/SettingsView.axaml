<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ZTalk.ViewModels"
             x:Class="ZTalk.Views.Controls.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <Grid ColumnDefinitions="200,1,*">
    <Border Grid.Column="0" Background="{DynamicResource App.Surface}" BorderThickness="0">
      <ListBox x:Name="MenuList" SelectedIndex="2" BorderThickness="0">
        <ListBoxItem Content="Appearance"/>
        <ListBoxItem Content="General"/>
        <ListBoxItem Content="Profile"/>
        <ListBoxItem Content="Network"/>
        <ListBoxItem Content="Performance"/>
        <ListBoxItem Content="Accessibility"/>
        <ListBoxItem Content="About"/>
        <ListBoxItem Content="Danger Zone"/>
        <ListBoxItem Tag="logout">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Classes="icon-mdl2" Text="&#xE7E8;" Foreground="#FF5757"/>
            <TextBlock Text="Log Out" Foreground="#FF5757"/>
          </StackPanel>
        </ListBoxItem>
      </ListBox>
    </Border>

  <!-- Vertical divider between menu and content -->
  <Border Grid.Column="1" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>

  <Grid Grid.Column="2">
      <!-- Profile Panel -->
      <ScrollViewer x:Name="ProfilePanel" IsVisible="True">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="Profile" FontWeight="SemiBold" FontSize="18"/>

          <!-- Card container matching prior layout -->
          <Border Background="{DynamicResource App.CardBackground}" CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="16">
              <!-- Identity Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="Identity" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="160,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" VerticalAlignment="Center"/>
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Username}" VerticalAlignment="Center"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="UID" VerticalAlignment="Center"/>
                  <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding DisplayUID}" VerticalAlignment="Center"/>
                    <Button Command="{Binding CopyUidCommand}" ToolTip.Tip="Copy UID" Padding="6,2" MinWidth="0">
                      <TextBlock Classes="icon-mdl2" Text="&#xE8C8;"/>
                    </Button>
                  </StackPanel>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Display Name" VerticalAlignment="Center"/>
                  <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DisplayName}" Watermark="Enter your display name"/>

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Prev. Name" VerticalAlignment="Center"/>
                  <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <ComboBox ItemsSource="{Binding DisplayNameHistory}" SelectedItem="{Binding SelectedPreviousDisplayName}" Width="220">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Border BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="12" Padding="8,2">
                      <TextBlock Text="{Binding DisplayNameChangeCount, StringFormat=Changes {0}}"/>
                    </Border>
                  </StackPanel>

                  <!-- Public Key row, visible only when enabled in General -->
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Public Key" VerticalAlignment="Center" IsVisible="{Binding ShowPublicKeys}"/>
                  <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowPublicKeys}">
                    <TextBlock Text="{Binding SelfPublicKeyHex}" TextTrimming="CharacterEllipsis" Width="420"/>
                    <Button Command="{Binding CopyPublicKeyCommand}" ToolTip.Tip="Copy Public Key" Padding="6,2" MinWidth="0">
                      <TextBlock Classes="icon-mdl2" Text="&#xE8C8;"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </StackPanel>

              <!-- Separator -->
              <Border BorderBrush="{DynamicResource App.Border}" BorderThickness="0,1,0,0"/>

              <!-- Avatar Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="Avatar" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="160,Auto,*" ColumnSpacing="12" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="Avatar" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="24" Background="{DynamicResource App.SecondaryBackground}">
                      <Image Source="{Binding AvatarPreview}" Stretch="UniformToFill"/>
                    </Border>
                    <Button Content="Choose..." Command="{Binding ChooseAvatarCommand}"/>
                    <Button Content="Clear" Command="{Binding ClearAvatarCommand}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Share Avatar with peers" VerticalAlignment="Center"/>
                    <ToggleSwitch IsChecked="{Binding ShareAvatar}"/>
                  </StackPanel>
                </Grid>
              </StackPanel>

              <!-- Separator -->
              <Border BorderBrush="{DynamicResource App.Border}" BorderThickness="0,1,0,0"/>

              <!-- About Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="About" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="160,*" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="Bio" VerticalAlignment="Top"/>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBox Text="{Binding Bio}" TextWrapping="Wrap" AcceptsReturn="True" Height="140"/>
                    <TextBlock Text="{Binding BioCounter}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" HorizontalAlignment="Right"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- General Panel -->
      <ScrollViewer x:Name="GeneralPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="General" FontWeight="SemiBold" FontSize="18"/>

          <!-- Presence -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="Default Presence" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="Status:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" SelectedIndex="{Binding DefaultPresenceIndex}" Width="150">
                  <ComboBoxItem Content="Online"/>
                  <ComboBoxItem Content="Away"/>
                  <ComboBoxItem Content="Busy"/>
                  <ComboBoxItem Content="Offline"/>
                </ComboBox>
              </Grid>
              <TextBlock Text="Offline is automatic only and cannot be selected." FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
            </StackPanel>
          </Border>

          <!-- Auto-Lock -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="Auto-Lock" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Enable Auto-Lock" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="0" Grid.Column="0" IsChecked="{Binding AutoLockEnabled}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Minutes" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="0" Grid.Column="4" Value="{Binding AutoLockMinutes}" Minimum="0" Maximum="1440" Width="64" ShowButtonSpinner="False" IsEnabled="{Binding AutoLockEnabled}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Lock on minimize" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="1" Grid.Column="0" IsChecked="{Binding LockOnMinimize}"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Lock Blur Radius -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="Lock Blur Radius" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="280,Auto" ColumnSpacing="12">
                <Slider Grid.Column="0" Value="{Binding LockBlurRadius}" Minimum="0" Maximum="10" Width="280"/>
    <Border Grid.Column="1"
                        BorderBrush="{DynamicResource App.Border}"
                        BorderThickness="1"
                        CornerRadius="4"
      Padding="6,0"
                        MinWidth="48"
      Height="28"
                        HorizontalAlignment="Left">
                  <TextBlock Text="{Binding LockBlurRadius}" VerticalAlignment="Center"/>
                </Border>
              </Grid>
              <TextBlock Text="Controls blur strength while locked. 0 = no blur, 10 = maximum." FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
            </StackPanel>
          </Border>

          <!-- Privacy -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="Privacy" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                <TextBlock Grid.Column="1" Text="Block screen capture" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding BlockScreenCapture}"/>
              </Grid>
              <TextBlock Text="Windows-only; older/legacy capture tools may not honor this." FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
            </StackPanel>
          </Border>

          <!-- Key Visibility -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="Key Visibility" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                <TextBlock Grid.Column="1" Text="Show public keys on profiles" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding ShowPublicKeys}"/>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Appearance Panel -->
      <ScrollViewer x:Name="AppearancePanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="18"/>
          
          <!-- Theme Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Theme" FontWeight="SemiBold"/>
              <ComboBox x:Name="ThemeCombo" SelectedIndex="{Binding ThemeIndex}" Width="180">
                <ComboBoxItem Content="Dark"/>
                <ComboBoxItem Content="Light"/>
                <ComboBoxItem Content="Sandy"/>
                <ComboBoxItem Content="Butter"/>
              </ComboBox>
            </StackPanel>
          </Border>

          <!-- Font Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Font" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Family:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding UiFontFamily}" Width="200" Watermark="Enter font family name"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Scale:" VerticalAlignment="Center"/>
                <Slider Value="{Binding UiScale}" Minimum="0.5" Maximum="3.0" Width="150" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding UiScale, StringFormat={}{0:F1}x}" VerticalAlignment="Center" Width="40"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
  </ScrollViewer>

      <ScrollViewer x:Name="PerformancePanel" IsVisible="False">
        <StackPanel x:Name="PerformanceStack" Margin="8" Spacing="16">
          <TextBlock Text="Performance" FontWeight="SemiBold" FontSize="18"/>
          
          <!-- CPU Section (first) -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="CPU" FontWeight="SemiBold"/>
              <!-- Enumerate CPU model and cache capabilities (model normal, details subtle) -->
              <TextBlock Text="{Binding CpuModel}"/>
              <TextBlock Text="{Binding VCacheInfo}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="CCD Affinity:" VerticalAlignment="Center"/>
                <ComboBox SelectedIndex="{Binding CcdAffinityIndex}" Width="150" ToolTip.Tip="{Binding CcdAffinityTooltip}">
                  <ComboBoxItem Content="Auto"/>
                  <ComboBoxItem Content="CCD 0"/>
                  <ComboBoxItem Content="CCD 1"/>
                  <ComboBoxItem Content="Both CCDs"/>
                </ComboBox>
                <!-- Inline red pill warning when Both CCDs is selected -->
                <Border
                  Background="{DynamicResource DangerButtonBackgroundColor}"
                  BorderBrush="{DynamicResource DangerButtonBorderColor}"
                  CornerRadius="12"
                  Padding="8,2"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  IsVisible="{Binding BothCcdWarningVisible}"
                  ToolTip.Tip="Using both CCDs can increase latency due to inter-CCD data transfers.">
                  <TextBlock Text="Not Recommended"
                             Foreground="{DynamicResource DangerButtonForegroundColor}"
                             FontWeight="SemiBold"
                             FontSize="12"/>
                </Border>
              </StackPanel>
              <TextBlock Text="{Binding CcdAffinityNotice}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" IsVisible="{Binding CcdAffinityNoticeVisible}"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Enforce RAM Limit" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnforceRamLimit}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding EnforceRamLimit}">
                <TextBlock Text="RAM Limit:" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding RamUsageLimitMb}" Minimum="0" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="MB (0 = unlimited)" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- GPU Section (moved after CPU) -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="GPU" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Enable GPU Acceleration" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnableGpuAcceleration}"/>
              </StackPanel>
              <TextBlock Text="{Binding GpuTextNotice}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Enforce VRAM Limit" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnforceVramLimit}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding EnforceVramLimit}">
                <TextBlock Text="VRAM Limit:" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding VramUsageLimitMb}" Minimum="0" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="MB (0 = unlimited)" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Framerate Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Framerate" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="FPS Throttle:" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding FpsThrottle}" Minimum="0" Maximum="300" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="fps (0 = unlimited)" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Refresh Rate Throttle:" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding RefreshRateThrottle}" Minimum="0" Maximum="300" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="hz (0 = unlimited)" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Background Framerate:" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding BackgroundFramerateFps}" Minimum="1" Maximum="60" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="fps" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="AccessibilityPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="Accessibility" FontWeight="SemiBold" FontSize="18"/>
          
          <!-- Display Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Display" FontWeight="SemiBold"/>
              <TextBlock Text="UI Scale and Font settings can be adjusted in the Appearance section." FontSize="14" Foreground="{DynamicResource App.SecondaryText}"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Current Scale:" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding UiScale, StringFormat={}{0:F1}x}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="(Adjust in Appearance tab)" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Font Rendering Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Font Rendering" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="OS Font Smoothing:" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OsFontSmoothingEnabled, StringFormat='{}{0}'}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="(System setting)" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Keyboard Navigation Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Keyboard Navigation" FontWeight="SemiBold"/>
              <TextBlock Text="Use Tab to navigate between controls, Space/Enter to activate buttons." FontSize="14" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="DebugPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="Debug Tools" FontWeight="SemiBold" FontSize="18"/>

          <Border CornerRadius="8" Padding="16" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Log Maintenance" FontWeight="SemiBold"/>

              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Auto-trim UI log" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnableDebugLogAutoTrim}"/>
              </StackPanel>

              <Grid ColumnDefinitions="220,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Max entries to keep" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding DebugUiLogMaxLines}" Minimum="100" Maximum="20000" Increment="100" Width="100" ShowButtonSpinner="False"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Retention window (days)" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding DebugLogRetentionDays}" Minimum="0" Maximum="30" Width="80" ShowButtonSpinner="False"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Size cap" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                  <NumericUpDown Value="{Binding DebugLogSizeValue}" Minimum="1" Maximum="{Binding DebugLogSizeMaxValue}" Width="80" ShowButtonSpinner="False"/>
                  <ComboBox SelectedItem="{Binding DebugLogSizeUnit}" Width="80" MinWidth="80">
                    <x:String>KB</x:String>
                    <x:String>MB</x:String>
                  </ComboBox>
                </StackPanel>
              </Grid>

              <StackPanel Spacing="4">
                <TextBlock Text="Last maintenance" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding LogMaintenanceLastRun}" Foreground="{DynamicResource App.SecondaryText}"/>
                <TextBlock Text="{Binding LogMaintenanceStatus}" TextWrapping="Wrap" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Run Maintenance Now" Command="{Binding RunLogMaintenanceCommand}"/>
                <Button Content="Clear Error Log" Command="{Binding ClearErrorLogCommand}" Background="{DynamicResource App.Warning}" Foreground="White" ToolTip.Tip="Trim error.log to last 500 entries (emergency cleanup)"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="AboutPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <!-- App Information -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Application Information" FontWeight="SemiBold" FontSize="16"/>
              <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" HorizontalAlignment="Stretch">
                <TextBlock Text="Name:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding AppName}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="Version:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="{Binding AppVersion}" VerticalAlignment="Center" FontWeight="Medium"/>
                  <Border Background="#FFA500" Padding="8,2" CornerRadius="4">
                    <TextBlock Text="InDev-Prototype" Foreground="Black" FontWeight="Bold"/>
                  </Border>
                </StackPanel>
                <TextBlock Text="Build:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Debug" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="Platform:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Windows" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="Author:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Author}" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Framework Information -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Framework Information" FontWeight="SemiBold" FontSize="16"/>
              <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" HorizontalAlignment="Stretch">
                <TextBlock Text="Avalonia UI:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding AvaloniaVersion}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text=".NET Runtime:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding DotNetVersion}" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Links and Resources -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Links &amp; Resources" FontWeight="SemiBold" FontSize="16"/>
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="8" RowSpacing="8">
                <Button Grid.Row="0" Grid.Column="0" Content="Documentation" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8"/>
                <Button Grid.Row="0" Grid.Column="1" Content="Privacy Policy" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Acknowledgments -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Acknowledgments" FontWeight="SemiBold" FontSize="16"/>
              <TextBlock Text="Built with Avalonia UI - A cross-platform XAML-based UI framework for .NET" TextWrapping="Wrap" Opacity="0.8"/>
              <TextBlock Text="Special thanks to the open source community for their contributions and support." TextWrapping="Wrap" Opacity="0.8"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Network Panel -->
      <ScrollViewer x:Name="NetworkPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="Network" FontWeight="SemiBold" FontSize="18"/>

          <!-- Connection Settings -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Connection" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Port" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Port}" Minimum="1" Maximum="65535" Width="120" ShowButtonSpinner="False"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Major Node" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="1" Grid.Column="1" IsChecked="{Binding MajorNode}" Content="Enable Major Node (requires port forwarding)"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Relay Settings -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Relay" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Relay Fallback" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="0" Grid.Column="1" IsChecked="{Binding RelayFallbackEnabled}" Content="Enable relay fallback for blocked connections"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Relay Server" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RelayServer}" Watermark="relay.example.com:443" Width="240"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Known Major Nodes -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Known Major Nodes" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding NewMajorNode}" Watermark="example.com:26264" Width="240"/>
                <Button Content="Add" Command="{Binding AddMajorNodeCommand}"/>
              </StackPanel>
              <Border Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" MinHeight="120" MaxHeight="200">
                <ScrollViewer>
                  <ItemsControl ItemsSource="{Binding KnownMajorNodes}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Margin="8,4">
                          <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"/>
                          <Button Grid.Column="1" Content="Remove" Command="{Binding $parent[UserControl].DataContext.RemoveMajorNodeCommand}" CommandParameter="{Binding}"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>
            </StackPanel>
          </Border>

          <!-- Discovered Peers (Table-like DHT Peer List) -->
          <Border CornerRadius="8" Padding="16" Width="920" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,4">
                <TextBlock Grid.Column="0" Text="Discovered Peers" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Block Selected" Command="{Binding BlockSelectedPeersCommand}" Margin="0,0,6,0" Padding="10,4" FontSize="12"/>
                <Button Grid.Column="2" Content="Unblock Selected" Command="{Binding UnblockSelectedPeersCommand}" Margin="0,0,6,0" Padding="10,4" FontSize="12"/>
                <Button Grid.Column="3" Command="{Binding RefreshPeersCommand}" Padding="8,4" ToolTip.Tip="Refresh Peer List" FontFamily="Segoe MDL2 Assets" FontSize="14" Content="&#xE72C;"/>
              </Grid>
              <Border Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Height="320">
                <Grid>
                  <!-- Table Header -->
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <Border Grid.Row="0" Background="{DynamicResource App.SecondaryBackground}" BorderBrush="{DynamicResource App.Border}" BorderThickness="0,0,0,1" Padding="6,4">
                    <Grid ColumnDefinitions="32,36,180,*,50,50">
                      <TextBlock Grid.Column="0" Text="☑" FontWeight="SemiBold" FontSize="11" Opacity="0.7" Margin="3,0,0,0"/>
                      <TextBlock Grid.Column="1" Text="🌍" FontWeight="SemiBold" FontSize="11" Opacity="0.7" HorizontalAlignment="Center"/>
                      <TextBlock Grid.Column="2" Text="UID" FontWeight="SemiBold" FontSize="11" Opacity="0.8" Margin="3,0,0,0"/>
                      <TextBlock Grid.Column="3" Text="Public Key" FontWeight="SemiBold" FontSize="11" Opacity="0.8" Margin="3,0,0,0"/>
                      <TextBlock Grid.Column="4" Text="Node" FontWeight="SemiBold" FontSize="11" Opacity="0.8" HorizontalAlignment="Center"/>
                      <TextBlock Grid.Column="5" Text="Block" FontWeight="SemiBold" FontSize="11" Opacity="0.8" HorizontalAlignment="Center"/>
                    </Grid>
                  </Border>
                  <!-- Scrollable peer list -->
                  <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ListBox x:Name="DiscoveredPeersList" 
                             ItemsSource="{Binding DiscoveredPeers}" 
                             SelectionMode="Multiple"
                             BorderThickness="0"
                             Background="Transparent">
                      <ListBox.Styles>
                        <!-- Alternating row colors -->
                        <Style Selector="ListBoxItem:nth-child(even)">
                          <Setter Property="Background" Value="{DynamicResource App.Surface}"/>
                        </Style>
                        <Style Selector="ListBoxItem:nth-child(odd)">
                          <Setter Property="Background" Value="{DynamicResource App.SecondaryBackground}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                          <Setter Property="Background" Value="{DynamicResource App.ItemSelected}"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                          <Setter Property="Background" Value="{DynamicResource App.ItemHover}"/>
                        </Style>
                      </ListBox.Styles>
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="32,36,180,*,50,50" Margin="6,3" HorizontalAlignment="Stretch">
                            <!-- Checkbox (implicit via SelectionMode=Multiple) -->
                            <CheckBox Grid.Column="0" IsChecked="{Binding $parent[ListBoxItem].IsSelected}" VerticalAlignment="Center" MinWidth="0" Padding="0" Margin="3,0,0,0"/>
                            
                            <!-- Country Flag (decorative, from IP - shows placeholder until connected) -->
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding CountryCode, FallbackValue='⚪'}" 
                                       FontSize="18" 
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       ToolTip.Tip="Region hint from IP (decorative)"/>
                            
                            <!-- UID with verified badge -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="3,0,0,0">
                              <TextBlock Text="{Binding DisplayUID}" 
                                         TextTrimming="CharacterEllipsis" 
                                         ToolTip.Tip="{Binding DisplayUID}"
                                         FontSize="11"
                                         VerticalAlignment="Center"
                                         MaxWidth="150"/>
                              <!-- Use VerifiedBadge control instead of circle -->
                              <ContentControl Width="14" Height="14"
                                              IsVisible="{Binding PublicKeyVerified}" 
                                              VerticalAlignment="Center"
                                              Content="{Binding}"
                                              ToolTip.Tip="Identity verified">
                                <ContentControl.ContentTemplate>
                                  <DataTemplate>
                                    <Viewbox Stretch="Uniform" Width="14" Height="14">
                                      <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource App.Success}"
                                              Data="M12,2 L20,6 V11 C20,15.75 16.92,19.87 12,21.75 7.08,19.87 4,15.75 4,11 V6 L12,2 Z"/>
                                        <Path Stroke="{DynamicResource App.OnSuccess}"
                                              StrokeThickness="2.2"
                                              StrokeLineCap="Round"
                                              StrokeJoin="Round"
                                              Data="M9.4,12.6 L11.9,15.1 16.6,9.6"/>
                                      </Canvas>
                                    </Viewbox>
                                  </DataTemplate>
                                </ContentControl.ContentTemplate>
                              </ContentControl>
                            </StackPanel>
                            
                            <!-- Public Key (with full UID tooltip on hover) -->
                            <TextBlock Grid.Column="3" 
                                       Text="{Binding PublicKeyDisplay}" 
                                       TextTrimming="CharacterEllipsis" 
                                       ToolTip.Tip="{Binding UID}"
                                       FontSize="10"
                                       VerticalAlignment="Center" 
                                       Margin="3,0,0,0"
                                       Foreground="{DynamicResource App.ForegroundSecondary}"/>
                            
                            <!-- Major Node indicator -->
                            <TextBlock Grid.Column="4" 
                                       Classes="icon-mdl2" 
                                       Text="&#xE774;" 
                                       Foreground="{DynamicResource App.Accent}" 
                                       IsVisible="{Binding IsMajorNode}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       ToolTip.Tip="Major Node"/>
                            
                            <!-- Block Status indicator -->
                            <Grid Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <!-- Blocked: Red Prohibition/Do Not Enter Sign -->
                              <TextBlock Classes="icon-mdl2" 
                                         Text="&#xF140;" 
                                         Foreground="#D32F2F" 
                                         FontSize="16"
                                         IsVisible="{Binding IsBlocked}"
                                         ToolTip.Tip="Blocked"/>
                              <!-- Not Blocked: Green Checkmark -->
                              <TextBlock Classes="icon-mdl2" 
                                         Text="&#xE73E;" 
                                         Foreground="#4CAF50" 
                                         FontSize="14"
                                         IsVisible="{Binding !IsBlocked}"
                                         ToolTip.Tip="Not Blocked"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </ScrollViewer>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <!-- Network Adapters -->
          <Border CornerRadius="8" Padding="16" Width="700" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Network Adapters" FontWeight="SemiBold"/>
              <TextBlock Text="Adapters at the top have priority for outbound connections" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <Border Grid.Column="0" Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Height="200">
                  <ScrollViewer>
                    <ListBox x:Name="AdaptersList" ItemsSource="{Binding NetworkAdapters}" SelectedItem="{Binding SelectedNetworkAdapter}" BorderThickness="0">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="8,6" Margin="2" CornerRadius="6" Background="Transparent" BorderThickness="1" BorderBrush="Transparent">
                            <Border.Styles>
                              <Style Selector="Border:listboxitem:selected">
                                <Setter Property="Background" Value="{DynamicResource App.ItemSelected}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
                              </Style>
                              <Style Selector="Border:pointerover">
                                <Setter Property="Background" Value="{DynamicResource App.ItemHover}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
                              </Style>
                            </Border.Styles>
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                              <TextBlock Text="{Binding Address}" FontSize="12" Foreground="{DynamicResource App.ForegroundSecondary}"/>
                              <TextBlock Text="{Binding Status}" FontSize="12" Foreground="{DynamicResource App.ForegroundSecondary}"/>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </ScrollViewer>
                </Border>
                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Top">
                  <Button Content="▲" Command="{Binding MoveAdapterUpCommand}" Width="32" Height="32" ToolTip.Tip="Move Up"/>
                  <Button Content="▼" Command="{Binding MoveAdapterDownCommand}" Width="32" Height="32" ToolTip.Tip="Move Down"/>
                  <Separator Margin="0,8"/>
                  <Button Content="Save" Command="{Binding SaveAdapterOrderCommand}" Width="64" ToolTip.Tip="Save adapter priority order"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="DangerPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <!-- Account Deletion Warning -->
          <Border CornerRadius="8" Padding="16" BorderBrush="Red" BorderThickness="1" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="⚠️ Danger Zone" FontWeight="SemiBold" FontSize="16" Foreground="Red"/>
              <TextBlock Text="These actions are irreversible and will permanently delete your data." TextWrapping="Wrap" Opacity="0.9"/>
            </StackPanel>
          </Border>

          <!-- Delete Account Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Delete Account" FontWeight="SemiBold" FontSize="16"/>
              <TextBlock Text="Once you delete your account, there is no going back. This will permanently delete your account and remove your data from our servers." TextWrapping="Wrap" Opacity="0.8"/>
              <TextBlock Text="Please type the following code to confirm:" Opacity="0.8"/>
              <Border CornerRadius="4" Padding="8" BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1" Width="320" HorizontalAlignment="Left">
                <TextBlock Text="{Binding GeneratedDeleteCode}" FontFamily="Consolas" FontWeight="Medium" HorizontalAlignment="Center"/>
              </Border>
              <TextBox Text="{Binding DeleteConfirmText}" Watermark="Enter confirmation code..." HorizontalAlignment="Left" Width="320"/>
              <Button Content="Delete Account" Command="{Binding DeleteAccountCommand}" Background="Red" Foreground="White" HorizontalAlignment="Left" Padding="12,8" FontWeight="Medium"/>
            </StackPanel>
          </Border>

          <!-- Purge Messages Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Purge All Messages" FontWeight="SemiBold" FontSize="16" Foreground="#C0392B"/>
              <TextBlock Text="Securely delete every conversation and pending message from this device. This process overwrites the encrypted archives before removal making recovery impossible." TextWrapping="Wrap" Opacity="0.85"/>
              <TextBlock Text="Use this if you're decommissioning the device or need a clean slate." TextWrapping="Wrap" Opacity="0.75"/>
              <Button Content="Purge All Messages" Command="{Binding PurgeAllMessagesCommand}" HorizontalAlignment="Left" Padding="12,8" FontWeight="Medium" Background="#B00020" Foreground="White"/>
            </StackPanel>
          </Border>

          <!-- Data Export -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Export Data" FontWeight="SemiBold" FontSize="16"/>
              <TextBlock Text="Download a copy of your data before deleting your account. This includes your messages, contacts, and settings." TextWrapping="Wrap" Opacity="0.8"/>
              <Button Content="Export Data" HorizontalAlignment="Left" Padding="12,8"/>
            </StackPanel>
          </Border>

          <!-- Additional Warnings -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="What happens when you delete your account?" FontWeight="SemiBold"/>
              <StackPanel Spacing="4" Opacity="0.8">
                <TextBlock Text="• All your messages will be permanently deleted" TextWrapping="Wrap"/>
                <TextBlock Text="• Your contact list will be removed" TextWrapping="Wrap"/>
                <TextBlock Text="• Your profile information will be erased" TextWrapping="Wrap"/>
                <TextBlock Text="• You will be removed from all conversations" TextWrapping="Wrap"/>
                <TextBlock Text="• This action cannot be undone" TextWrapping="Wrap"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="LogoutPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <!-- Logout Information -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Sign Out" FontWeight="SemiBold" FontSize="16"/>
              <TextBlock Text="Signing out will disconnect you from the application and require you to enter your passphrase again to access your account." TextWrapping="Wrap" Opacity="0.8"/>
              <TextBlock Text="Your data will remain securely stored locally and will be available when you sign back in." TextWrapping="Wrap" Opacity="0.8"/>
            </StackPanel>
          </Border>

          <!-- Current Session Info -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Current Session" FontWeight="SemiBold" FontSize="16"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" HorizontalAlignment="Stretch">
                <TextBlock Text="Status:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Active" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium" Foreground="Green"/>
                <TextBlock Text="Last Activity:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Just now" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Opacity="0.8"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Sign Out Button -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Ready to sign out?" FontWeight="SemiBold"/>
              <TextBlock Text="Click the button below to sign out of your account. You'll need your passphrase to sign back in." TextWrapping="Wrap" Opacity="0.8"/>
              <Button Content="Sign Out" Command="{Binding LogoutCommand}" Background="{DynamicResource App.Accent}" Foreground="White" HorizontalAlignment="Left" Padding="12,8" FontWeight="Medium"/>
            </StackPanel>
          </Border>

          <!-- Security Note -->
          <Border CornerRadius="8" Padding="16" BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="🔒 Security Reminder" FontWeight="SemiBold"/>
              <TextBlock Text="Always sign out when using shared or public computers to protect your privacy and security." TextWrapping="Wrap" Opacity="0.8"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
      <Grid Grid.Column="0" Grid.ColumnSpan="3" IsHitTestVisible="False" Panel.ZIndex="5">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0" Spacing="6">
          <Border IsVisible="{Binding UnsavedWarningVisible}"
                  Background="{DynamicResource App.Surface}"
                  BorderBrush="{DynamicResource DangerButtonBackgroundColor}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12,6"
                  MaxWidth="360"
                  Opacity="0.95">
            <TextBlock Text="{Binding UnsavedWarningText}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
          </Border>
          <Border IsVisible="{Binding SaveToastVisible}"
                  Background="{DynamicResource App.Surface}"
                  BorderBrush="{DynamicResource App.Accent}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12,6"
                  MaxWidth="360"
                  Opacity="0.95">
            <TextBlock Text="{Binding SaveToastText}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
          </Border>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:Zer0Talk"
             xmlns:vm="clr-namespace:Zer0Talk.ViewModels"
             x:Class="Zer0Talk.Views.Controls.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <Grid ColumnDefinitions="200,1,*">
    <Border Grid.Column="0" Background="{DynamicResource App.Surface}" BorderThickness="0">
      <ListBox x:Name="MenuList" SelectedIndex="0" BorderThickness="0">
        <ListBoxItem Content="{Binding LocalizedAppearance}"/>
        <ListBoxItem Content="{Binding LocalizedGeneral}"/>
        <ListBoxItem Content="{Binding LocalizedHotkeys}"/>
        <ListBoxItem Content="{Binding LocalizedProfile}"/>
        <ListBoxItem Content="{Binding LocalizedNetwork}"/>
        <ListBoxItem Content="{Binding LocalizedPerformance}"/>
        <ListBoxItem Content="{Binding LocalizedAccessibility}"/>
        <ListBoxItem Content="{Binding LocalizedAbout}"/>
        <ListBoxItem Content="{Binding LocalizedDangerZone}"/>
        <ListBoxItem Tag="logout">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Classes="icon-mdl2" Text="&#xE7E8;" Foreground="#FF5757"/>
            <TextBlock Text="{Binding LocalizedLogOut}" Foreground="#FF5757"/>
          </StackPanel>
        </ListBoxItem>
      </ListBox>
    </Border>

  <!-- Vertical divider between menu and content -->
  <Border Grid.Column="1" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>

  <Grid Grid.Column="2">
      <!-- Appearance Panel -->
      <ScrollViewer x:Name="AppearancePanel" IsVisible="True">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="{Binding LocalizedAppearance}" FontWeight="SemiBold" FontSize="18"/>
          
          <!-- Theme Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedTheme}" FontWeight="SemiBold"/>
              <ComboBox x:Name="ThemeCombo" ItemsSource="{Binding ThemeItems}" SelectedIndex="{Binding ThemeIndex}" Width="180"/>
            </StackPanel>
          </Border>

          <!-- Font Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedFont}" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedFamily}" VerticalAlignment="Center"/>
                <TextBox Text="{Binding UiFontFamily}" Width="200" Watermark="{Binding LocalizedEnterFontFamilyName}"/>
              </StackPanel>
              <!-- UI Scaling removed: OS-level scaling should be used instead (Windows Display Settings, etc.) -->
              <!-- DO NOT re-add UI scaling - RenderTransform scaling causes severe layout issues, content clipping, -->
              <!-- and window sizing problems that cannot be reliably solved. Use OS accessibility features instead. -->
              <TextBlock Text="{Binding LocalizedOSScalingMessage}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <!-- Language Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left" BorderBrush="{DynamicResource App.Accent}" BorderThickness="2">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedLanguage}" FontWeight="SemiBold"/>
              <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding Language}" Width="200" HorizontalAlignment="Left"/>
              <TextBlock Text="{Binding LocalizedAdditionalLanguagesMessage}" FontSize="11" Foreground="{DynamicResource App.SecondaryText}" Opacity="0.8"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- General Panel -->
      <ScrollViewer x:Name="GeneralPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="{Binding LocalizedGeneral}" FontWeight="SemiBold" FontSize="18"/>

          <!-- Presence -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding LocalizedDefaultPresence}" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="{Binding LocalizedStatus}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding PresenceItems}" SelectedIndex="{Binding DefaultPresenceIndex}" Width="150"/>
              </Grid>
              <TextBlock Text="{Binding LocalizedOfflineAutomatic}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12" Margin="0,8,0,0">
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding SuppressNotificationsInDnd}"/>
                <TextBlock Grid.Column="1" Text="{Binding LocalizedSuppressNotifications}" VerticalAlignment="Center"/>
              </Grid>
              
              <!-- Notification Duration Controls -->
              <StackPanel Spacing="8" Margin="0,12,0,0">
                <TextBlock Text="{Binding LocalizedNotificationDuration}" FontWeight="Medium"/>
                <Grid ColumnDefinitions="120,*,80,80" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                  <!-- Slider Row -->
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedDuration}" VerticalAlignment="Center" FontSize="12"/>
                  <Slider Grid.Row="0" Grid.Column="1" 
                          Minimum="0.5" Maximum="20" 
                          Value="{Binding NotificationDurationSeconds, Mode=TwoWay}"
                          TickFrequency="0.5" 
                          IsSnapToTickEnabled="True"
                          ToolTip.Tip="Drag to adjust notification display duration"/>
                  <Border Grid.Row="0" Grid.Column="2" 
                          BorderBrush="{DynamicResource App.Border}" 
                          BorderThickness="1" 
                          CornerRadius="4" 
                          Padding="6,0" 
                          Height="28" 
                          HorizontalAlignment="Center">
                    <TextBlock Text="{Binding NotificationDurationSeconds, StringFormat='{}{0:F1}s'}" 
                               VerticalAlignment="Center" 
                               FontFamily="Consolas" 
                               FontSize="11"/>
                  </Border>
                  
                  <!-- Input Box Row -->
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedPrecise}" VerticalAlignment="Center" FontSize="12"/>
                  <NumericUpDown Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                 Value="{Binding NotificationDurationSeconds, Mode=TwoWay}"
                                 Minimum="0.5"
                                 Maximum="30"
                                 Increment="0.5"
                                 FormatString="F1"
                                 ShowButtonSpinner="True"
                                 Width="120"
                                 HorizontalAlignment="Left"
                                 ToolTip.Tip="Enter precise duration (0.5 to 30 seconds)"/>
                </Grid>
                <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                  <Run Text="{Binding LocalizedNotificationDurationHelp}"/>
                  <Run Text="{Binding LocalizedCurrentSetting}"/>
                  <Run Text="{Binding NotificationDurationSeconds, StringFormat='{}{0:F1} '}" FontWeight="Medium"/>
                  <Run Text="{Binding LocalizedSeconds}" FontWeight="Medium"/>
                </TextBlock>
              </StackPanel>

              <!-- Notification Bell Flash -->
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12" Margin="0,8,0,0">
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding EnableNotificationBellFlash}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding LocalizedEnableNotificationBellFlash}" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding LocalizedNotificationBellFlashHelp}" 
                             FontSize="11" 
                             Foreground="{DynamicResource App.SecondaryText}"/>
                </StackPanel>
              </Grid>
              
            </StackPanel>
          </Border>

          <!-- Auto-Lock -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding LocalizedAutoLock}" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalizedEnableAutoLock}" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="0" Grid.Column="0" IsChecked="{Binding AutoLockEnabled}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding LocalizedMinutes}" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="0" Grid.Column="4" Value="{Binding AutoLockMinutes}" Minimum="0" Maximum="1440" Width="64" ShowButtonSpinner="False" IsEnabled="{Binding AutoLockEnabled}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LocalizedLockOnMinimize}" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="1" Grid.Column="0" IsChecked="{Binding LockOnMinimize}"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Lock Blur Radius -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding LocalizedLockBlurRadius}" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="280,Auto" ColumnSpacing="12">
                <Slider Grid.Column="0" Value="{Binding LockBlurRadius}" Minimum="0" Maximum="10" Width="280"/>
    <Border Grid.Column="1"
                        BorderBrush="{DynamicResource App.Border}"
                        BorderThickness="1"
                        CornerRadius="4"
      Padding="6,0"
                        MinWidth="48"
      Height="28"
                        HorizontalAlignment="Left">
                  <TextBlock Text="{Binding LockBlurRadius}" VerticalAlignment="Center"/>
                </Border>
              </Grid>
              <TextBlock Text="{Binding LocalizedLockBlurHelp}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
            </StackPanel>
          </Border>

          <!-- Privacy -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding LocalizedPrivacy}" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                <TextBlock Grid.Column="1" Text="{Binding LocalizedBlockScreenCapture}" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding BlockScreenCapture}"/>
              </Grid>
              <TextBlock Text="{Binding LocalizedScreenCaptureWarning}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
            </StackPanel>
          </Border>

          <!-- Key Visibility -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding LocalizedKeyVisibility}" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                <TextBlock Grid.Column="1" Text="{Binding LocalizedShowPublicKeys}" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding ShowPublicKeys}"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Audio Settings -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedAudio}" FontWeight="SemiBold"/>
              <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                <Run Text="{Binding LocalizedAudioHelp}"/>
              </TextBlock>
              
              <Grid ColumnDefinitions="120,*,60" RowDefinitions="Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                <!-- Main Volume -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedMainVolume}" VerticalAlignment="Center"/>
                <Slider Grid.Row="0" Grid.Column="1" 
                        Minimum="0" Maximum="1" 
                        Value="{Binding MainVolume, Mode=TwoWay}"
                        TickFrequency="0.1" IsSnapToTickEnabled="False"
                        ToolTip.Tip="Overall volume control for all sounds"/>
                <Border Grid.Row="0" Grid.Column="2" 
                        BorderBrush="{DynamicResource App.Border}" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Padding="6,0" 
                        MinWidth="48" 
                        Height="28" 
                        HorizontalAlignment="Center">
                  <TextBlock Text="{Binding MainVolume, StringFormat='{}{0:P0}'}" 
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Center"
                             FontFamily="Consolas" 
                             FontSize="11"/>
                </Border>
                
                <!-- Notification Volume -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedNotifications}" VerticalAlignment="Center"/>
                <Slider Grid.Row="1" Grid.Column="1" 
                        Minimum="0" Maximum="1" 
                        Value="{Binding NotificationVolume, Mode=TwoWay}"
                        TickFrequency="0.1" IsSnapToTickEnabled="False"
                        ToolTip.Tip="Volume for general notifications and alerts"/>
                <Border Grid.Row="1" Grid.Column="2" 
                        BorderBrush="{DynamicResource App.Border}" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Padding="6,0" 
                        MinWidth="48" 
                        Height="28" 
                        HorizontalAlignment="Center">
                  <TextBlock Text="{Binding NotificationVolume, StringFormat='{}{0:P0}'}" 
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Center"
                             FontFamily="Consolas" 
                             FontSize="11"/>
                </Border>
                
                <!-- Chat Volume -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LocalizedChatSounds}" VerticalAlignment="Center"/>
                <Slider Grid.Row="2" Grid.Column="1" 
                        Minimum="0" Maximum="1" 
                        Value="{Binding ChatVolume, Mode=TwoWay}"
                        TickFrequency="0.1" IsSnapToTickEnabled="False"
                        ToolTip.Tip="Volume for chat messages, calls, and voice notes"/>
                <Border Grid.Row="2" Grid.Column="2" 
                        BorderBrush="{DynamicResource App.Border}" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Padding="6,0" 
                        MinWidth="48" 
                        Height="28" 
                        HorizontalAlignment="Center">
                  <TextBlock Text="{Binding ChatVolume, StringFormat='{}{0:P0}'}" 
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Center"
                             FontFamily="Consolas" 
                             FontSize="11"/>
                </Border>
              </Grid>
              
              <TextBlock Text="💡 Effective volume = Main Volume × Channel Volume" 
                         FontSize="11" 
                         Foreground="{DynamicResource App.SecondaryText}" 
                         Opacity="0.75" 
                         FontStyle="Italic" 
                         Margin="0,4,0,0"/>
            </StackPanel>
          </Border>

          <!-- System Tray -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedSystemTray}" FontWeight="SemiBold"/>
              <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                <Run Text="{Binding LocalizedSystemTrayHelp}"/>
              </TextBlock>
              
              <!-- Show in System Tray -->
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding ShowInSystemTray}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding LocalizedShowSystemTrayIcon}" FontWeight="Medium"/>
                  <TextBlock Text="{Binding LocalizedShowSystemTrayIconHelp}" 
                             FontSize="11" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>

              <!-- Minimize to Tray -->
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding MinimizeToTray}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding LocalizedMinimizeToTray}" FontWeight="Medium"/>
                  <TextBlock Text="{Binding LocalizedMinimizeToTrayHelp}" 
                             FontSize="11" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>

              <!-- Run on Startup -->
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <ToggleSwitch Grid.Column="0" IsChecked="{Binding RunOnStartup}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding LocalizedRunOnStartup}" FontWeight="Medium"/>
                  <TextBlock Text="{Binding LocalizedRunOnStartupHelp}" 
                             FontSize="11" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Hotkeys Panel -->
      <ScrollViewer x:Name="HotkeysPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="{Binding LocalizedHotkeys}" FontWeight="SemiBold" FontSize="18"/>
          
          <TextBlock Text="{Binding LocalizedCustomizeKeyboardShortcuts}" Opacity="0.7" FontSize="13"/>
          <TextBlock Text="{Binding LocalizedHotkeyInstructions}" 
                     TextWrapping="Wrap" Opacity="0.7" FontSize="12"/>

          <!-- Lock Hotkey -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedLockApplication}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding LocalizedLockApplicationHelp}" 
                         Opacity="0.7" FontSize="12"/>
              <Grid ColumnDefinitions="160,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedHotkey}" VerticalAlignment="Center"/>
                <Border Grid.Row="0" Grid.Column="1" 
                        x:Name="LockHotkeyBox"
                        BorderBrush="{DynamicResource App.Border}" 
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{DynamicResource App.Background}"
                        Padding="12,8"
                        Cursor="Hand">
                  <Grid>
                    <TextBlock Text="{Binding LockHotkeyDisplay}" 
                               FontFamily="Consolas"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsCapturingLockHotkey}"/>
                    <TextBlock Text="{Binding LocalizedPressKeys}" 
                               Opacity="0.5"
                               IsVisible="{Binding IsCapturingLockHotkey}"
                               VerticalAlignment="Center"/>
                  </Grid>
                </Border>
                <Button Grid.Row="1" Grid.Column="1" 
                        Content="Reset to Default (Ctrl+L)" 
                        Command="{Binding ResetLockHotkeyCommand}"
                        HorizontalAlignment="Left"
                        Padding="10,6"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Clear Input Hotkey -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedClearMessageInput}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding LocalizedClearMessageInputHelp}" 
                         Opacity="0.7" FontSize="12"/>
              <Grid ColumnDefinitions="160,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedHotkey}" VerticalAlignment="Center"/>
                <Border Grid.Row="0" Grid.Column="1" 
                        x:Name="ClearInputHotkeyBox"
                        BorderBrush="{DynamicResource App.Border}" 
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{DynamicResource App.Background}"
                        Padding="12,8"
                        Cursor="Hand">
                  <Grid>
                    <TextBlock Text="{Binding ClearInputHotkeyDisplay}" 
                               FontFamily="Consolas"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsCapturingClearInputHotkey}"/>
                    <TextBlock Text="{Binding LocalizedPressKeys}" 
                               Opacity="0.5"
                               IsVisible="{Binding IsCapturingClearInputHotkey}"
                               VerticalAlignment="Center"/>
                  </Grid>
                </Border>
                <Button Grid.Row="1" Grid.Column="1" 
                        Content="Reset to Default (Ctrl+Shift+Q)" 
                        Command="{Binding ResetClearInputHotkeyCommand}"
                        HorizontalAlignment="Left"
                        Padding="10,6"/>
              </Grid>
            </StackPanel>
          </Border>

          <Border CornerRadius="8" Padding="12" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding LocalizedHotkeyTips}" FontWeight="SemiBold" FontSize="13"/>
              <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.75"
                         Text="{Binding LocalizedHotkeyTipsText}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Profile Panel -->
      <ScrollViewer x:Name="ProfilePanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="{Binding LocalizedProfile}" FontWeight="SemiBold" FontSize="18"/>

          <!-- Card container matching prior layout -->
          <Border Background="{DynamicResource App.CardBackground}" CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="16">
              <!-- Identity Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding LocalizedIdentity}" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="160,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" VerticalAlignment="Center"/>
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Username}" VerticalAlignment="Center"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="UID" VerticalAlignment="Center"/>
                  <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding DisplayUID}" VerticalAlignment="Center"/>
                    <Button Command="{Binding CopyUidCommand}" ToolTip.Tip="Copy UID" Padding="6,2" MinWidth="0">
                      <TextBlock Classes="icon-mdl2" Text="&#xE8C8;"/>
                    </Button>
                  </StackPanel>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LocalizedDisplayName}" VerticalAlignment="Center"/>
                  <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DisplayName}" Watermark="{Binding LocalizedEnterDisplayName}"/>

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding LocalizedPrevName}" VerticalAlignment="Center"/>
                  <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <ComboBox ItemsSource="{Binding DisplayNameHistory}" SelectedItem="{Binding SelectedPreviousDisplayName}" Width="220">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Border BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="12" Padding="8,2">
                      <TextBlock Text="{Binding DisplayNameChangeCount, StringFormat=Changes {0}}"/>
                    </Border>
                  </StackPanel>

                  <!-- Public Key row, visible only when enabled in General -->
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding LocalizedPublicKey}" VerticalAlignment="Center" IsVisible="{Binding ShowPublicKeys}"/>
                  <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowPublicKeys}">
                    <TextBlock Text="{Binding SelfPublicKeyHex}" TextTrimming="CharacterEllipsis" Width="420"/>
                    <Button Command="{Binding CopyPublicKeyCommand}" ToolTip.Tip="Copy Public Key" Padding="6,2" MinWidth="0">
                      <TextBlock Classes="icon-mdl2" Text="&#xE8C8;"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </StackPanel>

              <!-- Separator -->
              <Border BorderBrush="{DynamicResource App.Border}" BorderThickness="0,1,0,0"/>

              <!-- Avatar Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding LocalizedAvatar}" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="160,Auto,*" ColumnSpacing="12" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="{Binding LocalizedAvatar}" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="24" Background="{DynamicResource App.SecondaryBackground}">
                      <Image Source="{Binding AvatarPreview}" Stretch="UniformToFill"/>
                    </Border>
                    <Button Content="{Binding LocalizedChoose}" Command="{Binding ChooseAvatarCommand}"/>
                    <Button Content="{Binding LocalizedClear}" Command="{Binding ClearAvatarCommand}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LocalizedShareAvatar}" VerticalAlignment="Center"/>
                    <ToggleSwitch IsChecked="{Binding ShareAvatar}"/>
                  </StackPanel>
                </Grid>
              </StackPanel>

              <!-- Separator -->
              <Border BorderBrush="{DynamicResource App.Border}" BorderThickness="0,1,0,0"/>

              <!-- About Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding LocalizedAbout}" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="160,*" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="{Binding LocalizedBio}" VerticalAlignment="Top"/>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBox Text="{Binding Bio}" TextWrapping="Wrap" AcceptsReturn="True" Height="140"/>
                    <TextBlock Text="{Binding BioCounter}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" HorizontalAlignment="Right"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="PerformancePanel" IsVisible="False">
        <StackPanel x:Name="PerformanceStack" Margin="8" Spacing="16">
          <TextBlock Text="{Binding LocalizedPerformance}" FontWeight="SemiBold" FontSize="18"/>
          
          <!-- CPU Section (first) -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedCPU}" FontWeight="SemiBold"/>
              <!-- Enumerate CPU model and cache capabilities (model normal, details subtle) -->
              <TextBlock Text="{Binding CpuModel}"/>
              <TextBlock Text="{Binding VCacheInfo}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedCCDOffinity}" VerticalAlignment="Center"/>
                <ComboBox SelectedIndex="{Binding CcdAffinityIndex}" Width="150" ToolTip.Tip="{Binding CcdAffinityTooltip}">
                  <ComboBoxItem Content="{Binding LocalizedAuto}"/>
                  <ComboBoxItem Content="{Binding LocalizedCCD0}"/>
                  <ComboBoxItem Content="{Binding LocalizedCCD1}"/>
                  <ComboBoxItem Content="{Binding LocalizedBothCCDs}"/>
                </ComboBox>
                <!-- Inline red pill warning when Both CCDs is selected -->
                <Border
                  Background="{DynamicResource DangerButtonBackgroundColor}"
                  BorderBrush="{DynamicResource DangerButtonBorderColor}"
                  CornerRadius="12"
                  Padding="8,2"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  IsVisible="{Binding BothCcdWarningVisible}"
                  ToolTip.Tip="Using both CCDs can increase latency due to inter-CCD data transfers.">
                  <TextBlock Text="{Binding LocalizedNotRecommended}"
                             Foreground="{DynamicResource DangerButtonForegroundColor}"
                             FontWeight="SemiBold"
                             FontSize="12"/>
                </Border>
              </StackPanel>
              <TextBlock Text="{Binding CcdAffinityNotice}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" IsVisible="{Binding CcdAffinityNoticeVisible}"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedEnforceRAMLimit}" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnforceRamLimit}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding EnforceRamLimit}">
                <TextBlock Text="{Binding LocalizedRAMLimit}" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding RamUsageLimitMb}" Minimum="0" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="{Binding LocalizedMBUnlimited}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- GPU Section (moved after CPU) -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedGPU}" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedEnableGPUAcceleration}" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnableGpuAcceleration}"/>
              </StackPanel>
              <TextBlock Text="{Binding GpuTextNotice}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedEnforceVRAMLimit}" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnforceVramLimit}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding EnforceVramLimit}">
                <TextBlock Text="{Binding LocalizedVRAMLimit}" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding VramUsageLimitMb}" Minimum="0" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="{Binding LocalizedMBUnlimited}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Framerate Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedFramerate}" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedFPSThrottle}" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding FpsThrottle}" Minimum="0" Maximum="300" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="{Binding LocalizedFPSUnlimited}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedRefreshRateThrottle}" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding RefreshRateThrottle}" Minimum="0" Maximum="300" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="{Binding LocalizedHzUnlimited}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedBackgroundFramerate}" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding BackgroundFramerateFps}" Minimum="1" Maximum="60" Width="80" ShowButtonSpinner="False"/>
                <TextBlock Text="{Binding LocalizedFPS}" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="AccessibilityPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="{Binding LocalizedAccessibilityTitle}" FontWeight="SemiBold" FontSize="18"/>
          
          <!-- OS-Level Accessibility Settings -->
          <Border CornerRadius="8" Padding="16" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedAccessibilitySettings}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding LocalizedAccessibilityOSMessage}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
              <StackPanel Spacing="6" Margin="12,8,0,0">
                <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                  <Run Text="{Binding LocalizedDisplayScaling}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedDisplayScalingPath}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                  <Run Text="{Binding LocalizedHighContrast}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedHighContrastPath}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                  <Run Text="{Binding LocalizedAnimations}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedAnimationsPath}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                  <Run Text="{Binding LocalizedCursorSize}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedCursorSizePath}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                  <Run Text="{Binding LocalizedTextCursor}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedTextCursorPath}"/>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>



          <!-- Keyboard Navigation Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedKeyboardNavigation}" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <ToggleSwitch Grid.Row="0" Grid.Column="0" IsChecked="{Binding ShowKeyboardFocus}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalizedShowKeyboardFocusIndicators}" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="1" Grid.Column="0" IsChecked="{Binding EnhancedKeyboardNavigation}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LocalizedEnhancedKeyboardNavigation}" VerticalAlignment="Center"/>
              </Grid>
              
              <Border Background="{DynamicResource App.SecondaryBackground}" CornerRadius="6" Padding="12" BorderBrush="{DynamicResource App.Border}" BorderThickness="1">
                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding LocalizedNavigationKeys}" FontWeight="SemiBold" FontSize="13"/>
                  <StackPanel Spacing="4">
                    <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                      <Run Text="{Binding LocalizedTab}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedTabDescription}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                      <Run Text="{Binding LocalizedShiftTab}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedShiftTabDescription}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                      <Run Text="{Binding LocalizedSpaceEnter}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedSpaceEnterDescription}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                      <Run Text="{Binding LocalizedArrowKeys}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedArrowKeysDescription}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                      <Run Text="{Binding LocalizedEsc}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedEscDescription}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource App.SecondaryText}">
                      <Run Text="{Binding LocalizedCtrlL}" FontWeight="SemiBold"/> <Run Text="{Binding LocalizedCtrlLDescription}"/>
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Border>
              <TextBlock Text="{Binding LocalizedNavigationHelp}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <!-- Font Rendering Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedFontRendering}" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LocalizedOSFontSmoothing}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OsFontSmoothingEnabled, StringFormat='{}{0}'}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="(System setting)" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>
              <TextBlock Text="{Binding LocalizedFontSmoothingMessage}" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="DebugPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="{Binding LocalizedDebugTools}" FontWeight="SemiBold" FontSize="18"/>

          <!-- Logging Toggle -->
          <Border CornerRadius="8" Padding="16" MaxWidth="720" HorizontalAlignment="Left" Background="{DynamicResource App.Surface}" BorderBrush="#FFA500" BorderThickness="2">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedLogging}" FontWeight="SemiBold"/>
              
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding LocalizedEnableLogging}" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnableLogging}"/>
              </StackPanel>
              
              <Border Background="#33FFA500" Padding="12" CornerRadius="4">
                <StackPanel Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="icon-mdl2" Text="&#xE7BA;" FontSize="16" Foreground="#FFA500" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LocalizedPerformanceWarning}" FontWeight="SemiBold" Foreground="#FFA500"/>
                  </StackPanel>
                  <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" Text="{Binding LocalizedPerformanceWarningText}"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border CornerRadius="8" Padding="16" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedLogMaintenance}" FontWeight="SemiBold"/>

              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding LocalizedAutoTrimUILog}" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding EnableDebugLogAutoTrim}"/>
              </StackPanel>

              <Grid ColumnDefinitions="220,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedMaxEntries}" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding DebugUiLogMaxLines}" Minimum="100" Maximum="20000" Increment="100" Width="100" ShowButtonSpinner="False"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedRetentionDays}" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding DebugLogRetentionDays}" Minimum="0" Maximum="30" Width="80" ShowButtonSpinner="False"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LocalizedSizeCap}" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                  <NumericUpDown Value="{Binding DebugLogSizeValue}" Minimum="1" Maximum="{Binding DebugLogSizeMaxValue}" Width="80" ShowButtonSpinner="False"/>
                  <ComboBox SelectedItem="{Binding DebugLogSizeUnit}" Width="80" MinWidth="80">
                    <x:String>KB</x:String>
                    <x:String>MB</x:String>
                  </ComboBox>
                </StackPanel>
              </Grid>

              <StackPanel Spacing="4">
                <TextBlock Text="{Binding LocalizedLastMaintenance}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding LogMaintenanceLastRun}" Foreground="{DynamicResource App.SecondaryText}"/>
                <TextBlock Text="{Binding LogMaintenanceStatus}" TextWrapping="Wrap" Foreground="{DynamicResource App.SecondaryText}"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{Binding LocalizedRunMaintenanceNow}" Command="{Binding RunLogMaintenanceCommand}"/>
                <Button Content="{Binding LocalizedClearErrorLog}" Command="{Binding ClearErrorLogCommand}" Background="{DynamicResource App.Warning}" Foreground="White" ToolTip.Tip="{Binding LocalizedClearErrorLogTooltip}"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="AboutPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <!-- App Information -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedApplicationInformation}" FontWeight="SemiBold" FontSize="16"/>
              <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding LocalizedAboutName}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding AppName}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="{Binding LocalizedVersion}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" VerticalAlignment="Center" FontWeight="Medium"/>
                  <Border Background="#FFA500" Padding="8,2" CornerRadius="4">
                    <TextBlock Text="{x:Static core:AppInfo.PrototypeTag}" Foreground="Black" FontWeight="Bold"/>
                  </Border>
                </StackPanel>
                <TextBlock Text="{Binding LocalizedBuild}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Debug" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="{Binding LocalizedAboutPlatform}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Windows" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="{Binding LocalizedAboutAuthor}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Author}" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Framework Information -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedAboutFrameworkInfo}" FontWeight="SemiBold" FontSize="16"/>
              <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding LocalizedAboutAvaloniaUI}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding AvaloniaVersion}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="{Binding LocalizedAboutDotNetRuntime}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding DotNetVersion}" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Links and Resources -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedAboutLinksResources}" FontWeight="SemiBold" FontSize="16"/>
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="8" RowSpacing="8">
                <Button Grid.Row="0" Grid.Column="0" Content="{Binding LocalizedAboutDocumentation}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8"/>
                <Button Grid.Row="0" Grid.Column="1" Content="{Binding LocalizedAboutPrivacyPolicy}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Acknowledgments -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedAboutAcknowledgments}" FontWeight="SemiBold" FontSize="16"/>
              <TextBlock Text="{Binding LocalizedAboutBuiltWithAvalonia}" TextWrapping="Wrap" Opacity="0.8"/>
              <TextBlock Text="{Binding LocalizedAboutSpecialThanks}" TextWrapping="Wrap" Opacity="0.8"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Network Panel -->
      <ScrollViewer x:Name="NetworkPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <TextBlock Text="{Binding LocalizedNetwork}" FontWeight="SemiBold" FontSize="18"/>

          <!-- Connection Settings -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedConnectionSettings}" FontWeight="SemiBold"/>
              <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" MaxWidth="820">
                <Run Text="{Binding LocalizedPortLabel}"/>
                <Run Text="{Binding LocalizedPortDescription}"/>
              </TextBlock>
              <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedPort}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Port}" Width="120" HorizontalAlignment="Left" Watermark="26264"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedDedicatedPeerNode}" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="1" Grid.Column="1" IsChecked="{Binding MajorNode}" Content="{Binding LocalizedEnableDedicatedPeerNode}"/>
              </Grid>
              <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" MaxWidth="820" Margin="0,4,0,0">
                <Run Text="{Binding LocalizedDedicatedPeerNodeInfo}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedEnablesUPnP}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedMakesNodeAccessible}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedImprovesConnectivity}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedDoesNotRelay}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedRequiresPortForwarding}"/>
              </TextBlock>
            </StackPanel>
          </Border>

          <!-- Relay Settings -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedRelaySettings}" FontWeight="SemiBold"/>
              <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" MaxWidth="820">
                <Run Text="{Binding LocalizedRelayDescription1}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedRelayDescription2}"/>
              </TextBlock>
              <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedRelayFallback}" VerticalAlignment="Center"/>
                <ToggleSwitch Grid.Row="0" Grid.Column="1" IsChecked="{Binding RelayFallbackEnabled}" Content="{Binding LocalizedEnableRelayFallback}"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedRelayServer}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RelayServer}" Watermark="relay.example.com:443" Width="280" HorizontalAlignment="Left"/>
              </Grid>
              <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource App.SecondaryText}" MaxWidth="820" Margin="0,4,0,0">
                <Run Text="{Binding LocalizedRequirements}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedRequiresDedicatedRelay}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedServerMustBeConfigured}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedRelayFormat}"/>
                <LineBreak/>
                <Run Text="{Binding LocalizedLeaveBlankToDisable}"/>
              </TextBlock>
            </StackPanel>
          </Border>

          <!-- Known Dedicated Peer Nodes -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedKnownDedicatedPeerNodes}" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding NewMajorNode}" Watermark="example.com:26264" Width="240"/>
                <Button Content="{Binding LocalizedAdd}" Command="{Binding AddMajorNodeCommand}"/>
              </StackPanel>
              <Border Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" MinHeight="120" MaxHeight="200">
                <ScrollViewer>
                  <ItemsControl ItemsSource="{Binding KnownMajorNodes}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Margin="8,4">
                          <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"/>
                          <Button Grid.Column="1" Content="{Binding $parent[UserControl].DataContext.LocalizedRemove}" Command="{Binding $parent[UserControl].DataContext.RemoveMajorNodeCommand}" CommandParameter="{Binding}"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>
            </StackPanel>
          </Border>

          <!-- Discovered Peers (Table-like DHT Peer List) -->
          <Border CornerRadius="8" Padding="16" Width="920" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,4">
                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
                  <TextBlock Text="{Binding LocalizedDiscoveredPeers}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding LocalizedLocationsEstimated}" FontSize="11" Foreground="{DynamicResource App.SecondaryText}" Opacity="0.8"/>
                </StackPanel>
                <Button Grid.Column="1" Content="{Binding LocalizedBlockSelected}" Command="{Binding BlockSelectedPeersCommand}" Margin="0,0,6,0" Padding="10,4" FontSize="12"/>
                <Button Grid.Column="2" Content="{Binding LocalizedUnblockSelected}" Command="{Binding UnblockSelectedPeersCommand}" Margin="0,0,6,0" Padding="10,4" FontSize="12"/>
                <Button Grid.Column="3" Command="{Binding RefreshPeersCommand}" Padding="8,4" ToolTip.Tip="Refresh Peer List" FontFamily="Segoe MDL2 Assets" FontSize="14" Content="&#xE72C;"/>
              </Grid>
              <Border Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Height="320">
                <Grid>
                  <!-- Table Header -->
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <Border Grid.Row="0" Background="{DynamicResource App.SecondaryBackground}" BorderBrush="{DynamicResource App.Border}" BorderThickness="0,0,0,1" Padding="6,4">
                    <Grid ColumnDefinitions="32,36,180,*,50,50">
                      <TextBlock Grid.Column="0" Text="☑" FontWeight="SemiBold" FontSize="11" Opacity="0.7" Margin="3,0,0,0"/>
                      <TextBlock Grid.Column="1" Text="🌍" FontWeight="SemiBold" FontSize="11" Opacity="0.7" HorizontalAlignment="Center"/>
                      <TextBlock Grid.Column="2" Text="{Binding LocalizedUID}" FontWeight="SemiBold" FontSize="11" Opacity="0.8" Margin="3,0,0,0"/>
                      <TextBlock Grid.Column="3" Text="{Binding LocalizedPublicKey}" FontWeight="SemiBold" FontSize="11" Opacity="0.8" Margin="3,0,0,0"/>
                      <TextBlock Grid.Column="4" Text="{Binding LocalizedNode}" FontWeight="SemiBold" FontSize="11" Opacity="0.8" HorizontalAlignment="Center"/>
                      <TextBlock Grid.Column="5" Text="{Binding LocalizedBlock}" FontWeight="SemiBold" FontSize="11" Opacity="0.8" HorizontalAlignment="Center"/>
                    </Grid>
                  </Border>
                  <!-- Scrollable peer list -->
                  <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ListBox x:Name="DiscoveredPeersList" 
                             ItemsSource="{Binding DiscoveredPeers}" 
                             SelectionMode="Multiple"
                             BorderThickness="0"
                             Background="Transparent">
                      <ListBox.Styles>
                        <!-- Alternating row colors -->
                        <Style Selector="ListBoxItem:nth-child(even)">
                          <Setter Property="Background" Value="{DynamicResource App.Surface}"/>
                        </Style>
                        <Style Selector="ListBoxItem:nth-child(odd)">
                          <Setter Property="Background" Value="{DynamicResource App.SecondaryBackground}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                          <Setter Property="Background" Value="{DynamicResource App.ItemSelected}"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                          <Setter Property="Background" Value="{DynamicResource App.ItemHover}"/>
                        </Style>
                      </ListBox.Styles>
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="32,36,180,*,50,50" Margin="6,3" HorizontalAlignment="Stretch">
                            <!-- Checkbox (implicit via SelectionMode=Multiple) -->
                            <CheckBox Grid.Column="0" IsChecked="{Binding $parent[ListBoxItem].IsSelected}" VerticalAlignment="Center" MinWidth="0" Padding="0" Margin="3,0,0,0"/>
                            
                            <!-- Country Flag (decorative, from IP - shows placeholder until connected) -->
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding CountryCode, FallbackValue='⚪'}" 
                                       FontSize="18" 
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       ToolTip.Tip="Region hint from IP (decorative)"/>
                            
                            <!-- UID with verified badge -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="3,0,0,0">
                              <TextBlock Text="{Binding DisplayUID}" 
                                         TextTrimming="CharacterEllipsis" 
                                         ToolTip.Tip="{Binding DisplayUID}"
                                         FontSize="11"
                                         VerticalAlignment="Center"
                                         MaxWidth="150"/>
                              <!-- Use VerifiedBadge control instead of circle -->
                              <ContentControl Width="14" Height="14"
                                              IsVisible="{Binding PublicKeyVerified}" 
                                              VerticalAlignment="Center"
                                              Content="{Binding}"
                                              ToolTip.Tip="Identity verified">
                                <ContentControl.ContentTemplate>
                                  <DataTemplate>
                                    <Viewbox Stretch="Uniform" Width="14" Height="14">
                                      <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource App.Success}"
                                              Data="M12,2 L20,6 V11 C20,15.75 16.92,19.87 12,21.75 7.08,19.87 4,15.75 4,11 V6 L12,2 Z"/>
                                        <Path Stroke="{DynamicResource App.OnSuccess}"
                                              StrokeThickness="2.2"
                                              StrokeLineCap="Round"
                                              StrokeJoin="Round"
                                              Data="M9.4,12.6 L11.9,15.1 16.6,9.6"/>
                                      </Canvas>
                                    </Viewbox>
                                  </DataTemplate>
                                </ContentControl.ContentTemplate>
                              </ContentControl>
                            </StackPanel>
                            
                            <!-- Public Key (with full UID tooltip on hover) -->
                            <TextBlock Grid.Column="3" 
                                       Text="{Binding PublicKeyDisplay}" 
                                       TextTrimming="CharacterEllipsis" 
                                       ToolTip.Tip="{Binding UID}"
                                       FontSize="10"
                                       VerticalAlignment="Center" 
                                       Margin="3,0,0,0"
                                       Foreground="{DynamicResource App.ForegroundSecondary}"/>
                            
                            <!-- Dedicated Peer Node indicator -->
                            <TextBlock Grid.Column="4" 
                                       Classes="icon-mdl2" 
                                       Text="&#xE774;" 
                                       Foreground="{DynamicResource App.Accent}" 
                                       IsVisible="{Binding IsMajorNode}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       ToolTip.Tip="Dedicated Peer Node"/>
                            
                            <!-- Block Status indicator -->
                            <Grid Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <!-- Blocked: Red Prohibition/Do Not Enter Sign -->
                              <TextBlock Classes="icon-mdl2" 
                                         Text="&#xF140;" 
                                         Foreground="#D32F2F" 
                                         FontSize="16"
                                         IsVisible="{Binding IsBlocked}"
                                         ToolTip.Tip="Blocked"/>
                              <!-- Not Blocked: Green Checkmark -->
                              <TextBlock Classes="icon-mdl2" 
                                         Text="&#xE73E;" 
                                         Foreground="#4CAF50" 
                                         FontSize="14"
                                         IsVisible="{Binding !IsBlocked}"
                                         ToolTip.Tip="Not Blocked"/>
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </ScrollViewer>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <!-- Network Adapters -->
          <Border CornerRadius="8" Padding="16" Width="700" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="Network Adapters" FontWeight="SemiBold"/>
              <TextBlock Text="Adapters at the top have priority for outbound connections" FontSize="12" Foreground="{DynamicResource App.SecondaryText}"/>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <Border Grid.Column="0" Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Height="200">
                  <ScrollViewer>
                    <ListBox x:Name="AdaptersList" ItemsSource="{Binding NetworkAdapters}" SelectedItem="{Binding SelectedNetworkAdapter}" BorderThickness="0">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="8,6" Margin="2" CornerRadius="6" Background="Transparent" BorderThickness="1" BorderBrush="Transparent">
                            <Border.Styles>
                              <Style Selector="Border:listboxitem:selected">
                                <Setter Property="Background" Value="{DynamicResource App.ItemSelected}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
                              </Style>
                              <Style Selector="Border:pointerover">
                                <Setter Property="Background" Value="{DynamicResource App.ItemHover}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
                              </Style>
                            </Border.Styles>
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                              <TextBlock Text="{Binding Address}" FontSize="12" Foreground="{DynamicResource App.ForegroundSecondary}"/>
                              <TextBlock Text="{Binding Status}" FontSize="12" Foreground="{DynamicResource App.ForegroundSecondary}"/>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </ScrollViewer>
                </Border>
                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Top">
                  <Button Content="▲" Command="{Binding MoveAdapterUpCommand}" Width="32" Height="32" ToolTip.Tip="Move Up"/>
                  <Button Content="▼" Command="{Binding MoveAdapterDownCommand}" Width="32" Height="32" ToolTip.Tip="Move Down"/>
                  <Separator Margin="0,8"/>
                  <Button Content="Save" Command="{Binding SaveAdapterOrderCommand}" Width="64" ToolTip.Tip="Save adapter priority order"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <!-- IP Blocking Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="860" HorizontalAlignment="Left">
            <StackPanel Spacing="16">
              <TextBlock Text="Bad-Actor IP Blocking" FontWeight="SemiBold" FontSize="16"/>
              
              <!-- Status and Controls -->
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Column="0" Text="{Binding IpBlockingStats}" VerticalAlignment="Center" FontSize="12" Opacity="0.8"/>
                  <Button Grid.Column="1" Content="Import" Command="{Binding ImportIpListCommand}" Padding="8,4" FontSize="12"/>
                  <Button Grid.Column="2" Content="Export" Command="{Binding ExportIpListCommand}" Padding="8,4" FontSize="12"/>
                </Grid>
              </StackPanel>
              
              <!-- Manual IP Addition -->
              <StackPanel Spacing="8">
                <TextBlock Text="Add Individual IPs" FontWeight="Medium"/>
                <Grid ColumnDefinitions="200,Auto" ColumnSpacing="8">
                  <TextBox Grid.Column="0" Text="{Binding NewBadActorIp}" Watermark="e.g., 192.168.1.100" VerticalAlignment="Center"/>
                  <Button Grid.Column="1" Content="Add IP" Command="{Binding AddBadActorIpCommand}" VerticalAlignment="Center"/>
                </Grid>
              </StackPanel>
              
              <!-- CIDR Range Addition -->
              <StackPanel Spacing="8">
                <TextBlock Text="Add IP Ranges (CIDR)" FontWeight="Medium"/>
                <Grid ColumnDefinitions="200,Auto" ColumnSpacing="8">
                  <TextBox Grid.Column="0" Text="{Binding NewIpRange}" Watermark="e.g., 192.168.1.0/24" VerticalAlignment="Center"/>
                  <Button Grid.Column="1" Content="Add Range" Command="{Binding AddIpRangeCommand}" VerticalAlignment="Center"/>
                </Grid>
              </StackPanel>
              
              <!-- Current Block Lists -->
              <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <!-- Individual IPs -->
                <StackPanel Grid.Column="0" Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Blocked IPs" FontWeight="Medium" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Clear All" Command="{Binding ClearAllIpsCommand}" 
                            FontSize="11" Padding="6,2" VerticalAlignment="Center"
                            ToolTip.Tip="Remove all individual IP addresses from the block list. IP ranges will remain intact."/>
                  </Grid>
                  <Border Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Height="160">
                    <ScrollViewer>
                      <ListBox ItemsSource="{Binding BadActorIps}" SelectedItem="{Binding SelectedBadActorIp}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="4,2" ToolTip.Tip="{Binding CountryName}">
                              <TextBlock Grid.Column="0" Text="{Binding IpOrRange}" VerticalAlignment="Center" FontFamily="Consolas" FontSize="11"/>
                              <Border Grid.Column="1" Background="{DynamicResource App.Accent}" CornerRadius="3" Padding="4,1" Margin="4,0">
                                <TextBlock Text="{Binding CountryCode}" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                              </Border>
                              <Button Grid.Column="2" Content="✕" Command="{Binding $parent[UserControl].DataContext.RemoveBadActorIpCommand}" 
                                      CommandParameter="{Binding}" Width="20" Height="20" FontSize="10" Padding="0"/>
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </ScrollViewer>
                  </Border>
                </StackPanel>
                
                <!-- IP Ranges -->
                <StackPanel Grid.Column="1" Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Blocked Ranges" FontWeight="Medium" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Clear All" Command="{Binding ClearAllRangesCommand}" 
                            FontSize="11" Padding="6,2" VerticalAlignment="Center"
                            ToolTip.Tip="Remove all CIDR IP ranges from the block list. Individual IPs will remain intact."/>
                  </Grid>
                  <Border Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Height="160">
                    <ScrollViewer>
                      <ListBox ItemsSource="{Binding IpRanges}" SelectedItem="{Binding SelectedIpRange}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="4,2" ToolTip.Tip="{Binding CountryName}">
                              <TextBlock Grid.Column="0" Text="{Binding IpOrRange}" VerticalAlignment="Center" FontFamily="Consolas" FontSize="11"/>
                              <Border Grid.Column="1" Background="{DynamicResource App.Accent}" CornerRadius="3" Padding="4,1" Margin="4,0">
                                <TextBlock Text="{Binding CountryCode}" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                              </Border>
                              <Button Grid.Column="2" Content="✕" Command="{Binding $parent[UserControl].DataContext.RemoveIpRangeCommand}" 
                                      CommandParameter="{Binding}" Width="20" Height="20" FontSize="10" Padding="0"/>
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </ScrollViewer>
                  </Border>
                </StackPanel>
              </Grid>
              
              <!-- Information Text -->
              <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.75" MaxWidth="820">
                <Run Text="IP blocking helps protect against known bad actors and hostile infrastructure."/>
                <LineBreak/>
                <Run Text="• Individual IPs: Block specific IP addresses"/>
                <LineBreak/>
                <Run Text="• CIDR Ranges: Block entire network ranges (e.g., 192.168.1.0/24 blocks all IPs 192.168.1.1-254)"/>
                <LineBreak/>
                <Run Text="• Import: Place 'ip-blocklist.txt' in %APPDATA%\Zer0Talk\security\, Desktop, or Downloads"/>
                <LineBreak/>
                <Run Text="• Sources: Spamhaus, FireHOL, abuse.ch, commercial threat intelligence, etc."/>
                <LineBreak/>
                <Run Text="• Export: Backup your block lists with timestamps"/>
              </TextBlock>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="DangerPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <!-- Account Deletion Warning -->
          <Border CornerRadius="8" Padding="16" BorderBrush="Red" BorderThickness="1" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedDangerZoneTitle}" FontWeight="SemiBold" FontSize="16" Foreground="Red"/>
              <TextBlock Text="{Binding LocalizedDangerZoneWarning}" TextWrapping="Wrap" Opacity="0.9"/>
            </StackPanel>
          </Border>

          <!-- Delete Account Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedDeleteAccount}" FontWeight="SemiBold" FontSize="16"/>
              
              <!-- Information First - What will happen -->
              <StackPanel Spacing="4" Opacity="0.8">
                <TextBlock Text="{Binding LocalizedWhatHappens}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding LocalizedMessagesDeleted}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding LocalizedContactListRemoved}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding LocalizedProfileErased}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding LocalizedRemovedFromConversations}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding LocalizedCannotUndo}" TextWrapping="Wrap" FontWeight="Medium"/>
              </StackPanel>
              
              <TextBlock Text="{Binding LocalizedDeleteAccountWarning}" TextWrapping="Wrap" Opacity="0.8"/>
              <TextBlock Text="{Binding LocalizedTypeConfirmationCode}" Opacity="0.8"/>
              <Border CornerRadius="4" Padding="8" BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1" Width="320" HorizontalAlignment="Left">
                <TextBlock Text="{Binding GeneratedDeleteCode}" FontFamily="Consolas" FontWeight="Medium" HorizontalAlignment="Center"/>
              </Border>
              <TextBox Text="{Binding DeleteConfirmText}" Watermark="{Binding LocalizedEnterConfirmationCode}" HorizontalAlignment="Left" Width="320"/>
              <Button Content="{Binding LocalizedDeleteAccount}" Command="{Binding DeleteAccountCommand}" Background="Red" Foreground="White" HorizontalAlignment="Left" Padding="12,8" FontWeight="Medium"/>
            </StackPanel>
          </Border>

          <!-- Purge Messages Section -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedPurgeAllMessages}" FontWeight="SemiBold" FontSize="16" Foreground="#C0392B"/>
              
              <!-- Information First - What will happen -->
              <StackPanel Spacing="4" Opacity="0.8">
                <TextBlock Text="{Binding LocalizedWhatHappensPurge}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding LocalizedConversationsDeleted}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding LocalizedOutboxRemoved}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding LocalizedArchivesOverwritten}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding LocalizedRecoveryImpossible}" TextWrapping="Wrap" FontWeight="Medium"/>
                <TextBlock Text="{Binding LocalizedCannotUndo}" TextWrapping="Wrap" FontWeight="Medium"/>
              </StackPanel>
              
              <TextBlock Text="{Binding LocalizedPurgeWarning}" TextWrapping="Wrap" Opacity="0.85"/>
              <TextBlock Text="{Binding LocalizedPurgeUseCase}" TextWrapping="Wrap" Opacity="0.75"/>
              
              <TextBlock Text="{Binding LocalizedTypePurgeConfirm}" Opacity="0.8"/>
              <TextBox Text="{Binding PurgeConfirmText}" Watermark="{Binding LocalizedTypePurgeAllData}" HorizontalAlignment="Left" Width="320"/>
              <Button Content="{Binding LocalizedPurgeAllMessages}" Command="{Binding PurgeAllMessagesCommand}" HorizontalAlignment="Left" Padding="12,8" FontWeight="Medium" Background="#B00020" Foreground="White"/>
            </StackPanel>
          </Border>

          <!-- Data Export -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedExportData}" FontWeight="SemiBold" FontSize="16"/>
              <TextBlock Text="{Binding LocalizedExportDataDescription}" TextWrapping="Wrap" Opacity="0.8"/>
              <Button Content="{Binding LocalizedExportData}" HorizontalAlignment="Left" Padding="12,8"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="LogoutPanel" IsVisible="False">
        <StackPanel Margin="8" Spacing="16">
          <!-- Logout Information -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedSignOut}" FontWeight="SemiBold" FontSize="16"/>
              <TextBlock Text="{Binding LocalizedSignOutDescription}" TextWrapping="Wrap" Opacity="0.8"/>
              <TextBlock Text="{Binding LocalizedDataRemains}" TextWrapping="Wrap" Opacity="0.8"/>
            </StackPanel>
          </Border>

          <!-- Current Session Info -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedCurrentSession}" FontWeight="SemiBold" FontSize="16"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding LocalizedSessionStatus}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding LocalizedActive}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium" Foreground="Green"/>
                <TextBlock Text="{Binding LocalizedLastActivity}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding LocalizedJustNow}" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Opacity="0.8"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Sign Out Button -->
          <Border CornerRadius="8" Padding="16" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding LocalizedReadyToSignOut}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding LocalizedSignOutPrompt}" TextWrapping="Wrap" Opacity="0.8"/>
              <Button Content="{Binding LocalizedSignOutButton}" Command="{Binding LogoutCommand}" Background="{DynamicResource App.Accent}" Foreground="White" HorizontalAlignment="Left" Padding="12,8" FontWeight="Medium"/>
            </StackPanel>
          </Border>

          <!-- Security Note -->
          <Border CornerRadius="8" Padding="16" BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1" MaxWidth="680" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding LocalizedSecurityReminder}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding LocalizedSecurityReminderText}" TextWrapping="Wrap" Opacity="0.8"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
      <Grid Grid.Column="0" Grid.ColumnSpan="3" IsHitTestVisible="False" Panel.ZIndex="5">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0" Spacing="6">
          <Border IsVisible="{Binding UnsavedWarningVisible}"
                  Background="{DynamicResource App.Surface}"
                  BorderBrush="{DynamicResource DangerButtonBackgroundColor}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12,6"
                  MaxWidth="360"
                  Opacity="0.95">
            <TextBlock Text="{Binding UnsavedWarningText}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
          </Border>
          <Border IsVisible="{Binding SaveToastVisible}"
                  Background="{DynamicResource App.Surface}"
                  BorderBrush="{DynamicResource App.Accent}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12,6"
                  MaxWidth="360"
                  Opacity="0.95">
            <TextBlock Text="{Binding SaveToastText}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
          </Border>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
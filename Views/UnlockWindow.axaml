<!--
  Context: Unlocks existing account using passphrase.
  - Validates account container first; settings/contacts loaded only after successful decrypt.
  - On settings decrypt failure, SettingsService.ResetToDefaults is used with current passphrase.
  - Includes inline Lost Passphrase recovery which rotates to a new passphrase and re-encrypts containers.
  - Window is Topmost and non-closable until unlock; size/position persisted in %AppData%\ZTalk\unlock.window.json.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ZTalk.ViewModels"
    x:Class="ZTalk.Views.UnlockWindow"
    x:DataType="vm:UnlockViewModel"
  Title="ZTalk Sign In" Topmost="True"
        Width="420" Height="270"
        CanResize="False"
  ExtendClientAreaToDecorationsHint="True"
  ExtendClientAreaChromeHints="NoChrome"
  ExtendClientAreaTitleBarHeightHint="36"
        mc:Ignorable="d">
  <Window.DataContext>
    <vm:UnlockViewModel />
  </Window.DataContext>
  <!-- [CHROME] Custom client area; drag bar replaces OS title bar. -->
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Padding="6" BorderBrush="{DynamicResource App.Border}" BorderThickness="0 0 0 1" Background="{DynamicResource App.Background}"
            PointerPressed="DragBar_PointerPressed">
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="4" Background="Transparent"/>
  <TextBlock Grid.Column="1" Text="ZTalk Sign In" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        <Grid Grid.Column="2"/>
      </Grid>
    </Border>

  <Border Grid.Row="1" Padding="12" Background="{DynamicResource App.Background}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1">
    <Grid>
      <!-- Main content area -->
      <StackPanel Spacing="10">
      <!-- [TRUNC-OPTIN] Prevent header text from overflowing in narrow DPI scenarios. -->
      <TextBlock Classes="app-trunc" Text="Enter passphrase to unlock" FontWeight="SemiBold" Margin="0,0,0,4"/>
  <TextBox x:Name="PassphraseTextBox" PasswordChar="•" Watermark="Passphrase" Text="{Binding Passphrase, Mode=TwoWay}"/>
      <!-- Remember passphrase with external label to avoid content truncation on small scales -->
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="Remember passphrase" VerticalAlignment="Center"/>
        <ToggleSwitch IsChecked="{Binding RememberPassphrase, Mode=TwoWay}" ToolTip.Tip="Stores your passphrase securely. Do not enable this on shared devices."/>
      </StackPanel>
  <!-- [TRUNC-OPTIN] Error messages can be long; enable truncation with tooltip. -->
  <TextBlock Classes="app-trunc" Text="{Binding ErrorMessage}" Foreground="#F66"/>
  <!-- Button row: enforce minimum 12px spacing between adjacent action buttons -->
  <Grid ColumnDefinitions="Auto,*,Auto,12,Auto"
    ClipToBounds="True">
    <Button Grid.Column="0" Content="Close App" Click="CloseApp_Click" Margin="0"/>
    <Grid Grid.Column="1"/>
  <Button Grid.Column="2" Content="Lost Passphrase?" Click="LostPassphrase_Click" Margin="0"/>
    <!-- Column 3 is a fixed 12px spacer to guarantee separation at all DPIs -->
  <Button Grid.Column="4" Content="Sign In" IsDefault="True" Command="{Binding UnlockCommand}" Margin="0"/>
  </Grid>

      <!-- New passphrase confirmation (still inline, appears after recovery) -->
      <Border IsVisible="{Binding HasNewPassphrase}" Padding="8" CornerRadius="6" Background="#223" BorderBrush="#A7A" BorderThickness="1">
        <StackPanel Spacing="6">
          <TextBlock Text="Write down this new passphrase now. You will not be able to recover it later." TextWrapping="Wrap"/>
          <TextBox Text="{Binding NewPassphrase}" IsReadOnly="True" FontFamily="Consolas"/>
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="I saved it" Command="{Binding AcceptNewPassphraseCommand}"/>
          </StackPanel>
        </StackPanel>
      </Border>
      </StackPanel>
      
      <!-- Overlay Toast - No layout reflow -->
      <Border x:Name="UnlockToast" 
              ZIndex="1000"
              HorizontalAlignment="Center" 
              VerticalAlignment="Top" 
              Margin="0,-40,0,0"
              Background="{DynamicResource App.Surface}" 
              BorderBrush="{DynamicResource App.Accent}" 
              BorderThickness="2" 
              CornerRadius="8"
              Padding="12,8" 
              IsVisible="False" 
              Opacity="0.0"
              BoxShadow="0 4 16 2 #40000000"
              MinWidth="280"
              MaxWidth="360">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
            <ThicknessTransition Property="Margin" Duration="0:0:0.25" Easing="CubicEaseOut"/>
          </Transitions>
        </Border.Transitions>
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- Icon -->
          <TextBlock x:Name="UnlockToastIcon" 
                     Grid.Column="0" 
                     Classes="icon-mdl2" 
                     Text="&#xE946;" 
                     FontSize="16" 
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"/>
          <!-- Message -->
          <TextBlock x:Name="UnlockToastText" 
                     Grid.Column="1" 
                     Text="" 
                     FontSize="13" 
                     TextWrapping="Wrap"
                     VerticalAlignment="Center"/>
          <!-- Dismiss Button -->
          <Button x:Name="UnlockToastDismiss"
                  Grid.Column="2" 
                  Content="×" 
                  FontSize="18"
                  FontWeight="Bold"
                  Padding="8,0"
                  Margin="8,0,0,0"
                  MinWidth="0"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Dismiss"/>
        </Grid>
      </Border>
    </Grid>
  </Border>
  </Grid>
</Window>
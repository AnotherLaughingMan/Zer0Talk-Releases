<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Zer0Talk.ViewModels"
        xmlns:svc="clr-namespace:Zer0Talk.Services"
        x:Class="Zer0Talk.Views.RoomsWindow"
        x:DataType="vm:RoomsViewModel"
        Title="Rooms"
        Width="920" Height="580"
        MinWidth="720" MinHeight="440"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="36"
        Background="{DynamicResource App.Background}">

    <Window.DataContext>
        <vm:RoomsViewModel />
    </Window.DataContext>

    <!-- Root layout: title bar | divider | connection strip | divider | body -->
    <Grid RowDefinitions="Auto,1,Auto,1,*">

        <!-- ══ Custom title bar ════════════════════════════════════════ -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource App.Border}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource App.TitleBarBackground}"
                PointerPressed="DragBar_PointerPressed">
            <Grid ColumnDefinitions="*,Auto" Height="36" Margin="12,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="&#xE716;" Classes="icon-mdl2"
                               FontSize="16"
                               Foreground="{DynamicResource App.TitleBarForeground}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Rooms"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TitleBarForeground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="icon-button" ToolTip.Tip="Close" Click="Close_Click"
                        Width="40" Height="36" Padding="0"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                    <TextBlock Classes="icon-mdl2" Text="&#xE8BB;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- Divider -->
        <Border Grid.Row="1" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>

        <!-- ══ Server connection strip ═════════════════════════════════ -->
        <Border Grid.Row="2" Padding="12,6" Background="{DynamicResource App.Surface}">
            <Grid ColumnDefinitions="Auto,8,*,8,Auto,6,Auto,12,*">
                <TextBlock Grid.Column="0" Text="Server:"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource App.ForegroundSecondary}"/>
                <TextBox Grid.Column="2"
                         Text="{Binding HomeServerText, Mode=TwoWay}"
                         Watermark="host:port — e.g. chat.example.com:8444"
                         IsEnabled="{Binding IsDisconnected}"
                         Height="28" FontSize="12" VerticalContentAlignment="Center"/>
                <Button Grid.Column="4"
                        IsVisible="{Binding IsDisconnected}"
                        Content="Connect"
                        Command="{Binding ConnectCommand}"
                        Height="28" FontSize="12" Padding="10,0"/>
                <Button Grid.Column="4"
                        IsVisible="{Binding IsConnected}"
                        Content="Disconnect"
                        Command="{Binding DisconnectCommand}"
                        Height="28" FontSize="12" Padding="10,0"/>
                <!-- Online indicator dot -->
                <TextBlock Grid.Column="6" Text="●"
                           IsVisible="{Binding IsConnected}"
                           Foreground="#3CBA6C" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="8"
                           Text="{Binding ConnectStatus}"
                           FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource App.ForegroundSecondary}"/>
            </Grid>
        </Border>

        <!-- Divider -->
        <Border Grid.Row="3" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>

        <!-- ══ Body: room list | divider | detail ══════════════════════ -->
        <Grid Grid.Row="4" ColumnDefinitions="260,1,*">

            <!-- ── Left: room list + create form ───────────────────── -->
            <Grid Grid.Column="0" RowDefinitions="*,1,Auto" Background="{DynamicResource App.Surface}">

                <!-- Room list -->
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Rooms}"
                         SelectedItem="{Binding SelectedRoom, Mode=TwoWay}"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource App.ItemHover}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource App.ItemSelected}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:RoomEntry">
                            <Grid ColumnDefinitions="12,8,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                           FontSize="10" VerticalAlignment="Center"
                                           Foreground="{DynamicResource App.ForegroundSecondary}"/>
                                <StackPanel Grid.Column="2" Spacing="1">
                                    <TextBlock Text="{Binding RoomId}"
                                               FontSize="13" FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource App.ForegroundSecondary}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Divider above create form -->
                <Border Grid.Row="1" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>

                <!-- Create room form -->
                <StackPanel Grid.Row="2" Spacing="6" Margin="10">
                    <TextBlock Text="New Room"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.ForegroundSecondary}"/>
                    <TextBox Text="{Binding NewRoomName, Mode=TwoWay}"
                             Watermark="Room name"
                             Height="28" FontSize="12" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding NewRoomCap, Mode=TwoWay}"
                             Watermark="Member cap (default 20)"
                             Height="28" FontSize="12" VerticalContentAlignment="Center"/>
                    <Button Content="Create Room"
                            Command="{Binding CreateRoomCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="30" FontSize="12"/>
                </StackPanel>
            </Grid>

            <!-- Vertical divider -->
            <Border Grid.Column="1" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>

            <!-- ── Right: room detail ────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- Placeholder when no room is selected -->
                <StackPanel IsVisible="{Binding HasNoSelectedRoom}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="8">
                    <TextBlock Text="&#xE716;" Classes="icon-mdl2"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource App.ForegroundSecondary}"
                               Opacity="0.35"/>
                    <TextBlock Text="Select a room or create one"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource App.ForegroundSecondary}"
                               Opacity="0.7"/>
                </StackPanel>

                <!-- Room detail (shown only when a room is selected) -->
                <Grid RowDefinitions="Auto,1,Auto,*,Auto,1,Auto" IsVisible="{Binding HasSelectedRoom}">

                    <!-- Row 0: Room header -->
                    <Border Grid.Row="0" Padding="12,8">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedRoomId}"
                                           FontSize="15" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SelectedRoomStatusText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource App.ForegroundSecondary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Content="Refresh"
                                        Command="{Binding RefreshMembersCommand}"
                                        Height="28" FontSize="12" Padding="10,0"/>
                                <Button Content="Leave"
                                        Command="{Binding LeaveRoomCommand}"
                                        Height="28" FontSize="12" Padding="10,0"/>
                                <Button ToolTip.Tip="Copy Room ID"
                                        Click="CopyRoomId_Click"
                                        Height="28" Padding="8,0">
                                    <TextBlock Text="&#xE8C8;" Classes="icon-mdl2" FontSize="13"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Divider -->
                    <Border Grid.Row="1" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>

                    <!-- Row 2: Member count -->
                    <TextBlock Grid.Row="2"
                               Text="{Binding MemberCountText}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.ForegroundSecondary}"
                               Margin="12,6,12,2"/>

                    <!-- Row 3: Member list -->
                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding Members}"
                             SelectedItem="{Binding SelectedMember, Mode=TwoWay}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="10,5"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource App.ItemHover}"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource App.ItemSelected}"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="svc:RoomMember">
                                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                                VerticalAlignment="Center">
                                        <!-- UID pill -->
                                        <Border CornerRadius="4" Padding="6,2"
                                                Background="{DynamicResource App.Accent}">
                                            <TextBlock Text="{Binding Uid}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="200"/>
                                        </Border>
                                        <!-- Role badges -->
                                        <TextBlock Text="Admin" FontSize="11" Foreground="#FFA500"
                                                   IsVisible="{Binding IsAdmin}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Mod" FontSize="11" Foreground="#6AB0F5"
                                                   IsVisible="{Binding IsModerator}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Cross-server indicator -->
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource App.ForegroundSecondary}"
                                                   IsVisible="{Binding HomeServer, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                   VerticalAlignment="Center">
                                            <Run Text="@ "/>
                                            <Run Text="{Binding HomeServer}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Row 4: Member action bar (kick/ban selected member) -->
                    <Border Grid.Row="4"
                            IsVisible="{Binding HasSelectedMember}"
                            Padding="10,6"
                            Background="{DynamicResource App.Surface}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SelectedMemberLabel}"
                                       FontSize="12"
                                       Foreground="{DynamicResource App.ForegroundSecondary}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button Content="Kick"
                                        Command="{Binding KickMemberCommand}"
                                        Height="26" FontSize="12" Padding="10,0"/>
                                <Button Content="Ban"
                                        Command="{Binding BanMemberCommand}"
                                        Height="26" FontSize="12" Padding="10,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Divider -->
                    <Border Grid.Row="5" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>

                    <!-- Row 6: Invite form -->
                    <Border Grid.Row="6" Padding="10,8">
                        <Grid ColumnDefinitions="Auto,8,*,12,Auto,8,*,8,Auto">
                            <TextBlock Grid.Column="0" Text="Invite UID:"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource App.ForegroundSecondary}"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding InviteUid, Mode=TwoWay}"
                                     Watermark="UID to invite"
                                     Height="28" FontSize="12" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Home server:"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource App.ForegroundSecondary}"/>
                            <TextBox Grid.Column="6"
                                     Text="{Binding InviteHomeServer, Mode=TwoWay}"
                                     Watermark="Optional (cross-server routing)"
                                     Height="28" FontSize="12" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="8"
                                    Content="Send Invite"
                                    Command="{Binding InviteCommand}"
                                    Height="28" FontSize="12" Padding="10,0"/>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>

        </Grid>
    </Grid>
</Window>

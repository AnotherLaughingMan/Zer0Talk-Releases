<!-- Main window (Avalonia 11 compatible, single root) -->
<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:core="clr-namespace:Zer0Talk"
    xmlns:vm="clr-namespace:Zer0Talk.ViewModels"
    xmlns:v="clr-namespace:Zer0Talk.Views"
    xmlns:models="clr-namespace:Zer0Talk.Models"
    xmlns:util="clr-namespace:Zer0Talk.Utilities"
    xmlns:c="clr-namespace:Zer0Talk.Controls"
    xmlns:cm="clr-namespace:Zer0Talk.Controls.Markdown"

    xmlns:avedit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    xmlns:ctb="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"

    x:Class="Zer0Talk.Views.MainWindow"
    x:Name="RootWindow"
    x:DataType="vm:MainWindowViewModel"
    mc:Ignorable="d"
    Title="Zer0Talk"
    Width="1260"
    Height="760"
    MinWidth="1160"
    MinHeight="700"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="32">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <util:OwnOrSelectedNameConverter x:Key="OwnOrSelectedNameConverter" />
        <util:EditCountdownConverter x:Key="EditCountdownConverter" />
        <util:EditCountdownVisibleConverter x:Key="EditCountdownVisibleConverter" />
        <util:EditEnabledConverter x:Key="EditEnabledConverter" />
        <util:StringEqualsConverter x:Key="StringEqualsConverter" />
        <util:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
        <util:StringNotNullOrEmptyConverter x:Key="StringNotNullOrEmptyConverter" />
        <util:FirstNonEmptyStringConverter x:Key="FirstNonEmptyStringConverter" />
        <util:WidthFractionConverter x:Key="ChatBubbleWidthConverter" Fraction="0.9" />
        <SolidColorBrush x:Key="MarkdownSyntaxBaseForeground" Color="#000000" />
        
        <!-- Additional converters for XAML bindings -->
        <util:UidToAvatarConverter x:Key="UidToAvatarConverter" />
        <util:PresenceEqualsToBoolConverter x:Key="PresenceEqualsToBoolConverter" />
        <util:VerificationShieldVisibilityConverter x:Key="VerificationShieldVisibilityConverter" />
        <util:InverseBoolConverter x:Key="InverseBoolConverter" />
        <util:MessageSenderBrushConverter x:Key="MessageSenderBrushConverter" />
        <util:MessageIsFromContactConverter x:Key="MessageIsFromContactConverter" />
        <util:StringEqualsMultiConverter x:Key="StringEqualsMultiConverter" />
        <util:ObjectNotNullConverter x:Key="ObjectNotNullConverter" />
        <util:ByteArrayToBitmapConverter x:Key="ByteArrayToBitmapConverter" />
        <util:LastSeenTimestampVisibilityConverter x:Key="LastSeenTimestampVisibilityConverter" />
        <util:NotOrConverter x:Key="NotOrConverter" />
        <util:PresenceToDisplayStringConverter x:Key="PresenceToDisplayStringConverter" />
        <util:DebugUiBadgeVisibilityConverter x:Key="DebugUiBadgeVisibilityConverter" />
        <util:StreamerModeNameConverter x:Key="StreamerModeNameConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.message-container">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Transitions">
                <Setter.Value>
                    <Transitions>
                        <BrushTransition Property="Background" Duration="0:0:0.25" />
                    </Transitions>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="Border.message-container:pointerover">
            <Setter Property="Background" Value="#0AFFFFFF" />
        </Style>

        <Style Selector="StackPanel.hover-actions">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Transitions">
                <Setter.Value>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                    </Transitions>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="Border.message-container:pointerover StackPanel.hover-actions">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

        <Style Selector="TextBlock.message-meta">
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundSecondary}" />
        </Style>

        <Style Selector="Button.message-link-preview">
            <Setter Property="Background" Value="{DynamicResource App.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style Selector="Button.message-link-preview /template/ ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style Selector="Border.message-read-indicator">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- Obsolete Markdown.Avalonia styles removed -->
        <Style Selector="TextBlock.spoiler-placeholder">
            <Setter Property="Foreground" Value="{DynamicResource App.Accent}" />
            <Setter Property="Opacity" Value="0.94" />
        </Style>
        <Style Selector="Border.chat-spoiler">
            <Setter Property="Background" Value="{DynamicResource App.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Setter.Value>
                    <Transitions>
                        <BrushTransition Property="Background" Duration="0:0:0.12" />
                        <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                    </Transitions>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Border.chat-spoiler:pointerover">
            <Setter Property="Background" Value="{DynamicResource App.ItemHover}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}" />
        </Style>
        <!-- Tame tab underline and use subtle hover/selected visuals for TabControls -->
        <Style Selector="TabControl TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="TabControl TabItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource App.ItemHover}" />
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundPrimary}" />
        </Style>
        <Style Selector="TabControl TabItem:selected">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource App.Accent}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource App.Surface}">

        <!-- Drag bar with system buttons, lock/logout, and panel toggles -->
        <Border Grid.Row="0" Padding="6" BorderBrush="{DynamicResource App.Border}" BorderThickness="0 0 0 1" Background="{DynamicResource App.TitleBarBackground}"
                        PointerPressed="DragBar_PointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <!-- Left: compact app icon + title -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <Image x:Name="TitleAppIcon"
                  Width="32"
                  Height="32"
                  MinWidth="32"
                  MinHeight="32"
                  Stretch="Uniform"/>
              <TextBlock Text="Zer0Talk" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{DynamicResource App.TitleBarForeground}"/>
                </StackPanel>

                <!-- Center: Prototype tag, smack-dab in the middle -->
                <Grid Grid.Column="1" IsHitTestVisible="False">
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FFA500" Padding="10,3" CornerRadius="8">
                        <TextBlock Text="{x:Static core:AppInfo.PrototypeBadgeText}" Foreground="Black" FontWeight="Bold"/>
                    </Border>
                </Grid>

                <!-- Right: panel toggles, lock/logout, and system buttons -->
                <StackPanel x:Name="TitleRightActions" Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Border Background="#FFB300" CornerRadius="6" Padding="6,2" VerticalAlignment="Center" Margin="0,0,2,0">
                        <Border.IsVisible>
                            <MultiBinding Converter="{StaticResource DebugUiBadgeVisibilityConverter}" ConverterParameter="1360">
                                <Binding Path="IsDebugUi"/>
                                <Binding ElementName="RootWindow" Path="Bounds.Width"/>
                            </MultiBinding>
                        </Border.IsVisible>
                        <TextBlock Text="DEV UI" FontSize="10" FontWeight="SemiBold" Foreground="#141414"/>
                    </Border>
                    <!-- Debug: simulate invite + clear (hidden in Release builds) -->
                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding IsDebugUi}">
                        <Button Classes="icon-button" ToolTip.Tip="Simulate Invite" Command="{Binding SimulateInviteCommand}">
                            <TextBlock Classes="icon-mdl2" Text="&#xE7C5;"/>
                        </Button>
                        <Separator IsVisible="{Binding IsDebugUi}"/>
                        <Button Classes="icon-button" ToolTip.Tip="Test Info Toast" Command="{Binding TestInfoToastCommand}" IsVisible="{Binding IsDebugUi}">
                            <TextBlock Classes="icon-mdl2" Text="&#xE946;" Foreground="#4CAF50"/>
                        </Button>
                        <Button Classes="icon-button" ToolTip.Tip="Test Warning Toast" Command="{Binding TestWarningToastCommand}" IsVisible="{Binding IsDebugUi}">
                            <TextBlock Classes="icon-mdl2" Text="&#xE7BA;" Foreground="#FF9800"/>
                        </Button>
                        <Button Classes="icon-button" ToolTip.Tip="Test Error Toast" Command="{Binding TestErrorToastCommand}" IsVisible="{Binding IsDebugUi}">
                            <TextBlock Classes="icon-mdl2" Text="&#xE783;" Foreground="#F44336"/>
                        </Button>
                        <Button Classes="icon-button" ToolTip.Tip="Test Message Toast" Command="{Binding TestMessageToastCommand}" IsVisible="{Binding IsDebugUi}">
                            <TextBlock Classes="icon-mdl2" Text="&#xE8BD;" Foreground="#2196F3"/>
                        </Button>
                    </StackPanel>
                    <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedToggleContacts}" Click="ToggleLeftPanel_Click">
                        <TextBlock Classes="icon-mdl2" Text="&#xE700;"/>
                    </Button>
                    <Button x:Name="NotificationBellButton" Classes="icon-button" ToolTip.Tip="{Binding LocalizedOpenNotifications}" Click="ToggleRightPanel_Click">
                        <!-- Bell glyph with compact red-dot badge to mirror nav rail -->
                        <Grid Width="20" Height="20">
                            <Path x:Name="NotificationBellIcon" Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource App.ForegroundPrimary}" IsHitTestVisible="False"
                                  Data="M12,2 C8.7,2 6,4.7 6,8 L6,11.3 C6,11.76 5.8,12.2 5.45,12.5 L4,14 L20,14 L18.55,12.5 C18.2,12.2 18,11.76 18,11.3 L18,8 C18,4.7 15.3,2 12,2 Z M9,18 C9,19.66 10.34,21 12,21 C13.66,21 15,19.66 15,18 Z"/>
                            <Ellipse Width="8" Height="8" Fill="#DD3333" Stroke="{DynamicResource App.Background}" StrokeThickness="1"
                                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                     IsHitTestVisible="False" IsVisible="{Binding NotificationBadgeVisible}" />
                        </Grid>
                    </Button>
                    <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedLockLogout}" Click="Lock_Click">
                        <TextBlock Classes="icon-mdl2" Text="&#xE72E;"/>
                    </Button>
                    <Separator/>
                    <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedMinimize}" Click="Minimize_Click">
                        <TextBlock Classes="icon-mdl2" Text="&#xE921;"/>
                    </Button>
                    <Button x:Name="MaximizeRestoreButton" Classes="icon-button" ToolTip.Tip="{Binding LocalizedMaximize}" Click="Maximize_Click">
                        <TextBlock x:Name="MaximizeRestoreIcon" Classes="icon-mdl2" Text="&#xE922;"/>
                    </Button>
                    <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedClose}" Click="Close_Click">
                        <TextBlock Classes="icon-mdl2" Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body: four columns (Nav rail | Contacts | Chat | Notifications) -->
        <Grid x:Name="BodyGrid" Grid.Row="1" Background="{DynamicResource App.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <!-- Divider column (contacts/chat) -->
                <ColumnDefinition Width="1"/>
                <!-- Chat star occupies remaining space -->
                <ColumnDefinition Width="*" MinWidth="360"/>
                <!-- Divider column (chat/notifications) -->
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="260" MinWidth="220"/>
            </Grid.ColumnDefinitions>
            <!-- Vertical dividers -->
            <Border Grid.Column="2" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>
            <Border Grid.Column="4" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>
            <!-- Nav rail: always visible -->
    <Border x:Name="NavRail" Grid.Column="0" BorderBrush="{DynamicResource App.Border}" BorderThickness="0 0 0 0" Background="{DynamicResource App.Surface}">
                <Border.Styles>
                    <!-- Scope: only nav rail icon buttons -->
                    <Style Selector="Button.icon-button">
                        <Setter Property="Width" Value="64"/>
                        <Setter Property="Height" Value="56"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <!-- 8px horizontal padding to match Discord-style containment -->
                        <Setter Property="Padding" Value="8,0"/>
                    </Style>
                </Border.Styles>
        <Grid Margin="0,12" RowDefinitions="Auto,*,Auto">
                    <!-- Primary navigation icons stay anchored to the top -->
                    <StackPanel Grid.Row="0" Spacing="6" HorizontalAlignment="Center">
                        <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedHome}" Click="Home_Click">
                            <TextBlock Classes="icon-mdl2" Text="&#xE80F;" FontSize="26"/>
                        </Button>
                        <Button x:Name="LogsButton" Classes="icon-button" ToolTip.Tip="{Binding LocalizedLogs}" Click="Logs_Click" IsVisible="False">
                            <TextBlock Classes="icon-mdl2" Text="&#xE8A5;" FontSize="26"/>
                        </Button>
                    </StackPanel>

                    <!-- Settings lives at the bottom edge to match navigation expectations -->
                    <StackPanel Grid.Row="2" Spacing="6" HorizontalAlignment="Center">
                        <Button x:Name="SettingsMenuButton" Classes="icon-button" ToolTip.Tip="{Binding LocalizedSettings}" Click="SettingsMenu_Click">
                            <TextBlock Classes="icon-mdl2" Text="&#xE713;" FontSize="26"/>
                            <Button.ContextMenu>
                                <ContextMenu Placement="Right" HorizontalOffset="8" VerticalOffset="0" Opacity="0.95"
                                             Background="{DynamicResource App.Background}"
                                             BorderBrush="{DynamicResource App.Border}">
                                    <ContextMenu.Styles>
                                        <Style Selector="MenuItem">
                                            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundPrimary}"/>
                                        </Style>
                                        <Style Selector="MenuItem:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource App.ItemHover}"/>
                                        </Style>
                                    </ContextMenu.Styles>
                                    <MenuItem Click="SettingsMenu_AllSettings_Click">
                                        <MenuItem.Header>
                                            <Border Background="{DynamicResource App.Success}" CornerRadius="999" Padding="16,3" MinWidth="124" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Grid ColumnDefinitions="20,*,20" MinWidth="124">
                                                    <TextBlock Grid.Column="0" Classes="icon-mdl2" Text="&#xE713;" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="All Settings" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Click="SettingsMenu_Monitoring_Click">
                                        <MenuItem.Header>
                                            <Grid ColumnDefinitions="20,*,20" MinWidth="124">
                                                <TextBlock Grid.Column="0" Classes="icon-mdl2" Text="&#xE946;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="Monitoring" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            </Grid>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Click="SettingsMenu_DiscoveredPeers_Click">
                                        <MenuItem.Header>
                                            <Grid ColumnDefinitions="20,*,20" MinWidth="124">
                                                <TextBlock Grid.Column="0" Classes="icon-mdl2" Text="&#xE77B;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="Discovered Peers" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            </Grid>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Click="SettingsMenu_ThemeEditor_Click">
                                        <MenuItem.Header>
                                            <Grid ColumnDefinitions="20,*,20" MinWidth="124">
                                                <TextBlock Grid.Column="0" Classes="icon-mdl2" Text="&#xE790;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="Theme Editor" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            </Grid>
                                        </MenuItem.Header>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Contacts -->
            <Grid x:Name="LeftPanelRoot" Grid.Column="1" RowDefinitions="Auto,*">
                <!-- Header area: identity + controls -->
                <Border Padding="8" Background="{DynamicResource App.Background}" BorderBrush="{DynamicResource App.Border}" BorderThickness="0 0 1 0">
                    <StackPanel Spacing="2">
                        <!-- Current user identity shown above the contacts list -->
                        <Border Padding="8" CornerRadius="6" Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <!-- User avatar: larger than contact avatars -->
                                <Border x:Name="UserAvatar" Width="44" Height="44" CornerRadius="22" Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" PointerPressed="UserAvatar_PointerPressed">
                                    <Border.ContextMenu>
                                        <ContextMenu Placement="Right" HorizontalOffset="8" VerticalOffset="0" Opacity="0.95"
                                                     Background="{DynamicResource App.Background}"
                                                     BorderBrush="{DynamicResource App.Border}"
                                                     x:DataType="vm:MainWindowViewModel">
                                            <ContextMenu.Styles>
                                                <Style Selector="MenuItem">
                                                    <Setter Property="Foreground" Value="{DynamicResource App.ForegroundPrimary}"/>
                                                </Style>
                                                <Style Selector="MenuItem:pointerover">
                                                    <Setter Property="Background" Value="{DynamicResource App.ItemHover}"/>
                                                </Style>
                                            </ContextMenu.Styles>
                                            <MenuItem Header="{Binding LocalizedViewProfile}" Command="{Binding $parent[v:MainWindow].OpenProfileSettingsCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedOnline}" Command="{Binding $parent[v:MainWindow].SetStatusOnlineCommand}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#x2714;" FontSize="12" IsVisible="{Binding $parent[v:MainWindow].IsOnline}"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedAway}" Command="{Binding $parent[v:MainWindow].SetStatusAwayCommand}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#x2714;" FontSize="12" IsVisible="{Binding $parent[v:MainWindow].IsAway}"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedDoNotDisturb}" Command="{Binding $parent[v:MainWindow].SetStatusDndCommand}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#x2714;" FontSize="12" IsVisible="{Binding $parent[v:MainWindow].IsDnd}"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding LocalizedInvisible}" Command="{Binding $parent[v:MainWindow].SetStatusOfflineCommand}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#x2714;" FontSize="12" IsVisible="{Binding $parent[v:MainWindow].IsOffline}"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <TextBlock Classes="icon-mdl2" Text="&#xE77B;" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                                        <c:AvatarImage Classes="avatar-img" Source="{Binding IdentityAvatarImage}" Stretch="UniformToFill"/>
                                        <!-- Presence dot overlay (Online=solid green; Idle/DND=icons; Invisible=hollow) -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="14" Height="14" CornerRadius="7" Background="{DynamicResource App.Background}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1">
                                            <Grid>
                                                <Ellipse Width="10" Height="10" Fill="#22CC66" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding $parent[v:MainWindow].IsOnline}"/>
                                                <Image Width="10" Height="10" Source="avares://Zer0Talk/Assets/Icons/Status/Away.ico" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding $parent[v:MainWindow].IsAway}"/>
                                                <Image Width="10" Height="10" Source="avares://Zer0Talk/Assets/Icons/Status/DND.ico" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding $parent[v:MainWindow].IsDnd}"/>
                                                <Ellipse Width="10" Height="10" Stroke="#888888" StrokeThickness="1.6" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding $parent[v:MainWindow].IsOffline}"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                                <StackPanel Spacing="0">
                                    <TextBlock FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                                <Binding Path="LoggedInUsername"/>
                                                <Binding Path="IsStreamerMode"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Opacity="0.7">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                                <Binding Path="LoggedInUidShort"/>
                                                <Binding Path="IsStreamerMode"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Contacts bar: title + add button -->
                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{Binding LocalizedContacts}" FontWeight="SemiBold"/>
                            <Button Grid.Column="1" Classes="icon-button" ToolTip.Tip="{Binding LocalizedAddContact}" Click="AddContact_Click">
                                        <TextBlock Classes="icon-mdl2" Text="&#xE710;"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#F66"/>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="1" x:Name="ContactsList" ItemsSource="{Binding Contacts}" SelectedItem="{Binding SelectedContact}"
                         Padding="4" BorderThickness="0" Background="Transparent">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Contact">
                <Border Classes="contact-card"
                    Margin="0,2,0,2"
                    Padding="10,8"
                    BorderThickness="1"
                                    ContextRequested="ContactCard_ContextRequested"
                                    DoubleTapped="ContactCard_DoubleTapped">
                                <Border.ContextMenu>
                                    <ContextMenu Placement="Pointer" HorizontalOffset="6" VerticalOffset="0" Opacity="0.95"
                                                x:DataType="models:Contact">
                                        <ContextMenu.DataContext>
                                            <Binding />
                                        </ContextMenu.DataContext>
                                        <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedViewProfile}"
                                                  Command="{Binding $parent[v:MainWindow].DataContext.ShowFullProfileCommand}"
                                                  CommandParameter="{Binding UID}">
                                            <MenuItem.Icon>
                                                <TextBlock Classes="icon-mdl2" Text="&#xE77B;"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedCopyUID}" Click="CopyContactUid_Click"
                                                  CommandParameter="{Binding UID}">
                                            <MenuItem.Icon>
                                                <TextBlock Classes="icon-mdl2" Text="&#xE8C8;"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <!-- DEPRECATED: Mark as trusted (replaced by cryptographic verification) -->
                                        <!-- MenuItem Header="Mark as trusted" removed per design decision -->
                                        <!-- MenuItem Header="Remove trusted flag" removed per design decision -->
                                        <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedSetSimulatedPresence}"
                                                  IsVisible="{Binding IsSimulated}">
                                            <MenuItem.Items>
                                                <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedOnline}"
                                                          Command="{Binding $parent[v:MainWindow].DataContext.SetSimulatedContactOnlineCommand}"
                                                          CommandParameter="{Binding UID}"/>
                                                <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedOffline}"
                                                          Command="{Binding $parent[v:MainWindow].DataContext.SetSimulatedContactOfflineCommand}"
                                                          CommandParameter="{Binding UID}"/>
                                            </MenuItem.Items>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="{Binding $parent[v:MainWindow].DataContext.LocalizedRemoveContact}"
                                                  Command="{Binding $parent[v:MainWindow].DataContext.RemoveContactCommand}"
                                                  CommandParameter="{Binding UID}">
                                            <MenuItem.Icon>
                                                <TextBlock Classes="icon-mdl2" Text="&#xE74D;"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Grid Width="44" Height="44">
                                        <Border Width="44" Height="44" CornerRadius="22"
                                                Background="{DynamicResource App.Surface}"
                                                BorderBrush="{DynamicResource App.Border}"
                                                BorderThickness="1">
                                            <Grid>
                                                <TextBlock Classes="icon-mdl2" Text="&#xE77B;" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"/>
                                                <c:AvatarImage Stretch="UniformToFill">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource UidToAvatarConverter}">
                                                            <Binding Path="UID"/>
                                                            <Binding Path="$parent[v:MainWindow].DataContext.AvatarVersion"/>
                                                        </MultiBinding>
                                                    </Image.Source>
                                                </c:AvatarImage>
                                            </Grid>
                                        </Border>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="16" Height="16"
                                                CornerRadius="8"
                                                Background="{DynamicResource App.Background}"
                                                BorderBrush="{DynamicResource App.Border}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Ellipse Width="10" Height="10" Fill="#22CC66" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         IsVisible="{Binding Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=Online}"/>
                                                <Image Width="10" Height="10" Source="avares://Zer0Talk/Assets/Icons/Status/Away.ico" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=Idle}"/>
                                                <Image Width="10" Height="10" Source="avares://Zer0Talk/Assets/Icons/Status/DND.ico" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=DoNotDisturb}"/>
                                                <Ellipse Width="10" Height="10" Stroke="#888888" StrokeThickness="1.4" Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         IsVisible="{Binding Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=Invisible}"/>
                                                <Ellipse Width="10" Height="10" Fill="Transparent" Stroke="#888888" StrokeThickness="1.6" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         IsVisible="{Binding Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=Offline}"/>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                                        <Binding Path="DisplayName"/>
                                                        <Binding Path="$parent[v:MainWindow].DataContext.IsStreamerMode"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <c:VerifiedBadge Width="16" Height="16" VerticalAlignment="Center">
                                                <c:VerifiedBadge.IsVisible>
                                                    <MultiBinding Converter="{StaticResource VerificationShieldVisibilityConverter}">
                                                        <Binding Path="PublicKeyVerified"/>
                                                        <Binding Path="IsVerified"/>
                                                        <Binding Path="IsSimulated"/>
                                                    </MultiBinding>
                                                </c:VerifiedBadge.IsVisible>
                                            </c:VerifiedBadge>
                                            <Border Background="#DA7C19" CornerRadius="4" Padding="4,1" VerticalAlignment="Center"
                                                    IsVisible="{Binding IsSimulated}">
                                                <TextBlock Text="{Binding $parent[v:MainWindow].DataContext.LocalizedSimulated}" Foreground="White" FontSize="11"/>
                                            </Border>
                                            <Border Background="#2B7A0B" CornerRadius="4" Padding="4,1" VerticalAlignment="Center"
                                                    IsVisible="{Binding IsTrusted}">
                                                <TextBlock Text="{Binding $parent[v:MainWindow].DataContext.LocalizedTrusted}" Foreground="White" FontSize="11"/>
                                            </Border>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                                            <TextBlock FontSize="12" Opacity="0.65">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                                        <Binding Path="DisplayUID"/>
                                                        <Binding Path="$parent[v:MainWindow].DataContext.IsStreamerMode"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Presence, Converter={StaticResource PresenceToDisplayStringConverter}}" FontSize="12" Opacity="0.6"/>
                                                <Border Background="#444" CornerRadius="4" Padding="4,1" IsVisible="{Binding LastKnownEncrypted}">
                                                    <TextBlock Text="{Binding $parent[v:MainWindow].DataContext.LocalizedEncrypted}" Foreground="White" FontSize="10"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LastPresenceUtc, StringFormat='{}{0:HH:mm}'}" FontSize="11" Opacity="0.5">
                                            <TextBlock.IsVisible>
                                                <MultiBinding Converter="{StaticResource LastSeenTimestampVisibilityConverter}">
                                                    <Binding Path="Presence"/>
                                                    <Binding Path="LastPresenceUtc"/>
                                                </MultiBinding>
                                            </TextBlock.IsVisible>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Center: Chat (simplified) with a persistent left divider -->
            <!-- Chat column now at index 3 due to inserted divider columns -->
            <Grid x:Name="ChatArea" Grid.Column="3" RowDefinitions="Auto,*,Auto" MinWidth="340" Background="{DynamicResource App.Background}">
                <Border Padding="12" BorderBrush="{DynamicResource App.Border}" BorderThickness="0 0 0 1" Background="{DynamicResource App.Background}">
                    <StackPanel Orientation="Vertical" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock FontSize="16" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                            <Binding Path="SelectedContactIdentity"/>
                                            <Binding Path="IsStreamerMode"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Opacity="0.6">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                            <Binding Path="SelectedContact.DisplayUID"/>
                                            <Binding Path="IsStreamerMode"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <c:VerifiedBadge Width="18" Height="18" VerticalAlignment="Center">
                                    <c:VerifiedBadge.IsVisible>
                                        <MultiBinding Converter="{StaticResource VerificationShieldVisibilityConverter}">
                                            <Binding Path="SelectedContact.PublicKeyVerified"/>
                                            <Binding Path="SelectedContact.IsVerified"/>
                                            <Binding Path="SelectedContact.IsSimulated"/>
                                        </MultiBinding>
                                    </c:VerifiedBadge.IsVisible>
                                </c:VerifiedBadge>
                            </StackPanel>
                            <Button Grid.Column="1" Width="28" Height="28" Margin="0,0,8,0" Classes="icon-button" Command="{Binding BurnConversationCommand}" ToolTip.Tip="{Binding LocalizedBurnConversation}">
                                <Grid Width="16" Height="16">
                                    <Path Fill="{DynamicResource App.Accent}" StrokeThickness="0" Stretch="Uniform"
                                          Data="M8,1 C9.5,3 9,4.6 9.4,6 C10.7,5.2 12,6.6 12,8.7 C12,11.1 10.2,13 8,13 C5.8,13 4,11.1 4,8.6 C4,7 4.9,5.8 6.2,5.1 C6.1,6.9 6.9,8.1 7.9,9.0 C8.8,9.9 9.6,9.4 9.6,8.1 C9.6,6.7 8.4,6.1 8,4.7 C7.6,3.4 7.9,2.2 8,1 Z"/>
                                </Grid>
                            </Button>
                            <Image Grid.Column="2" Width="16" Height="16" ToolTip.Tip="{Binding LocalizedChatEncrypted}" VerticalAlignment="Center" IsVisible="{Binding IsChatEncrypted}" Source="{DynamicResource Icon.Encrypted}"/>
                        </Grid>

                        <Border CornerRadius="6" Padding="10,6" HorizontalAlignment="Stretch"
                                Background="{DynamicResource App.Surface}"
                                BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                                IsVisible="{Binding OfflineBannerVisible}" Opacity="{Binding OfflineBannerOpacity}">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                                </Transitions>
                            </Border.Transitions>
                            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="&#xE70B;" Classes="icon-mdl2"/>
                                <TextBlock Grid.Column="1" Text="{Binding OfflineBannerText}"/>
                            </Grid>
                        </Border>
                        <Border Background="#DA7C19" CornerRadius="4" Padding="6,2" IsVisible="{Binding IsSelectedContactSimulated}" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding LocalizedSimulatedContact}" FontSize="11" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" x:Name="ChatScroll" ScrollChanged="ChatScroll_ScrollChanged" SizeChanged="ChatScroll_SizeChanged">
                    <Grid RowDefinitions="Auto,Auto">
                        <ItemsControl Grid.Row="0" ItemsSource="{Binding TimelineItems}">
                            <ItemsControl.DataTemplates>
                                <DataTemplate x:DataType="vm:ChatTimelineDateHeader">
                                    <Grid Margin="0,24,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Height="1" Background="{DynamicResource App.Border}" Margin="0,12,12,12" VerticalAlignment="Center" Opacity="0.5"/>
                                        <Border Grid.Column="2" Height="1" Background="{DynamicResource App.Border}" Margin="12,12,0,12" VerticalAlignment="Center" Opacity="0.5"/>
                    <Border Grid.Column="1" Padding="12,4" CornerRadius="0"
                                                Background="{DynamicResource App.Surface}"
                                                BorderBrush="{DynamicResource App.Border}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Opacity="0.85"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                                <DataTemplate x:DataType="models:Message">
                                    <Border Classes="message-container message-row"
                                            Padding="8"
                                            Margin="0,0,0,12">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" VerticalAlignment="Top">
                                                <Grid>
                                                    <TextBlock Classes="icon-mdl2" Text="&#xE77B;" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"/>
                                                    <c:AvatarImage Stretch="UniformToFill">
                                                        <Image.Source>
                                                            <MultiBinding Converter="{StaticResource UidToAvatarConverter}">
                                                                <Binding Path="SenderUID" />
                                                                <Binding Path="$parent[v:MainWindow].DataContext.AvatarVersion" />
                                                            </MultiBinding>
                                                        </Image.Source>
                                                    </c:AvatarImage>
                                                </Grid>
                                            </Border>
                                            <Border Grid.Column="1" CornerRadius="0" Padding="0" Background="Transparent" BorderThickness="0" MaxWidth="{Binding $parent[v:MainWindow].((vm:MainWindowViewModel)DataContext).ChatViewportWidth, Converter={StaticResource ChatBubbleWidthConverter}}" HorizontalAlignment="Stretch">
                                                <StackPanel Spacing="6" SizeChanged="MessageContent_SizeChanged">
                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                                                        <TextBlock FontWeight="SemiBold" Opacity="0.95">
                                                            <TextBlock.Foreground>
                                                                <MultiBinding Converter="{StaticResource MessageSenderBrushConverter}">
                                                                    <Binding Path="SenderUID" />
                                                                    <Binding Path="$parent[v:MainWindow].DataContext.LoggedInUidFull" />
                                                                </MultiBinding>
                                                            </TextBlock.Foreground>
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource OwnOrSelectedNameConverter}">
                                                                    <Binding Path="SenderUID" />
                                                                    <Binding Path="$parent[v:MainWindow].DataContext.LoggedInUidFull" />
                                                                    <Binding Path="RecipientUID" />
                                                                    <Binding Path="$parent[v:MainWindow].DataContext.SelectedContact.UID" />
                                                                    <Binding Path="$parent[v:MainWindow].DataContext.LoggedInUsername" />
                                                                    <Binding Path="$parent[v:MainWindow].DataContext.SelectedContactIdentity" />
                                                                    <Binding Path="$parent[v:MainWindow].DataContext.UiTick" />
                                                                    <Binding Path="$parent[v:MainWindow].DataContext.IsStreamerMode" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                            <TextBlock Classes="message-meta" FontSize="11" Opacity="0.65" Text="{Binding Timestamp}"/>
                                                            <TextBlock Classes="message-meta" FontSize="11" Opacity="0.55" Text="{Binding $parent[v:MainWindow].DataContext.LocalizedEdited}" IsVisible="{Binding IsEdited}"/>
                                                            
                                                            <!-- Dot indicator for incoming messages (messages we received) -->
                                                            <Grid Width="14" Height="14" VerticalAlignment="Center" ToolTip.Tip="{Binding $parent[v:MainWindow].DataContext.LocalizedMessageReceived}">
                                                                <Grid.IsVisible>
                                                                    <MultiBinding Converter="{StaticResource MessageIsFromContactConverter}">
                                                                        <Binding Path="SenderUID" />
                                                                        <Binding Path="$parent[v:MainWindow].DataContext.LoggedInUidFull" />
                                                                    </MultiBinding>
                                                                </Grid.IsVisible>
                                                                <Ellipse Width="5" Height="5" Fill="{DynamicResource App.ForegroundSecondary}" />
                                                            </Grid>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" x:Name="MessageHoverBar" Classes="hover-actions" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                                            <Button Width="24" Height="24" MinWidth="24" MinHeight="24" IsTabStop="False"
                                                                    Classes="icon-button"
                                                                    ToolTip.Tip="{Binding $parent[v:MainWindow].DataContext.LocalizedEdit}"
                                                                    Command="{Binding $parent[v:MainWindow].DataContext.EditMessageCommand}"
                                                                    CommandParameter="{Binding Id}">
                                                                <Button.IsEnabled>
                                                                    <MultiBinding Converter="{StaticResource EditEnabledConverter}">
                                                                        <Binding />
                                                                        <Binding Path="$parent[v:MainWindow].DataContext" />
                                                                    </MultiBinding>
                                                                </Button.IsEnabled>
                                                                <Button.IsVisible>
                                                                    <MultiBinding Converter="{StaticResource StringEqualsMultiConverter}">
                                                                        <Binding Path="SenderUID" />
                                                                        <Binding Path="$parent[v:MainWindow].DataContext.LoggedInUidFull" />
                                                                    </MultiBinding>
                                                                </Button.IsVisible>
                                                                <TextBlock Classes="icon-mdl2" Text="&#xE70F;"/>
                                                            </Button>
                                                            <Button Width="24" Height="24" MinWidth="24" MinHeight="24" IsTabStop="False"
                                                                    Classes="icon-button"
                                                                    ToolTip.Tip="{Binding $parent[v:MainWindow].DataContext.LocalizedDelete}"
                                                                    Command="{Binding $parent[v:MainWindow].DataContext.DeleteMessageCommand}"
                                                                    CommandParameter="{Binding Id}">
                                                                <TextBlock Classes="icon-mdl2" Text="&#xE74D;"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid>
                                                        <cm:Zer0TalkMarkdownViewer Markdown="{Binding RenderedContent}"
                                                                              IsVisible="{Binding $parent[v:MainWindow].DataContext.UseMarkdig}" />
                                                        <TextBlock Text="{Binding RenderedContent}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="8"
                                                                   IsVisible="{Binding $parent[v:MainWindow].DataContext.UseMarkdig, Converter={StaticResource InverseBoolConverter}}" />
                                                    </Grid>
                                                    <Button Classes="message-link-preview"
                                                            Content="{Binding LinkPreview}"
                                                            Command="{Binding $parent[v:MainWindow].DataContext.OpenLinkCommand}"
                                                            CommandParameter="{Binding LinkPreview}"
                                                            HorizontalAlignment="Stretch">
                                                        <Button.IsVisible>
                                                            <Binding Path="Content"
                                                                     RelativeSource="{RelativeSource Self}"
                                                                     Converter="{StaticResource ObjectNotNullConverter}" />
                                                        </Button.IsVisible>
                                                        <Button.ContentTemplate>
                                                            <DataTemplate x:DataType="models:LinkPreview">
                                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" HorizontalAlignment="Left">
                                    <Border Grid.Column="0"
                                        Width="72"
                                        Height="72"
                                        CornerRadius="6"
                                        Background="#332D2D2D" 
                                        BorderBrush="{DynamicResource App.Border}" 
                                        BorderThickness="1">
                                                                        <Grid ClipToBounds="True">
                                                                            <Rectangle Fill="#44242424" RadiusX="6" RadiusY="6"/>
                                                                            <Image Stretch="UniformToFill"
                                                                                   Source="{Binding ImageBytes, Converter={StaticResource ByteArrayToBitmapConverter}}"/>
                                                                        </Grid>
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                                        <TextBlock FontSize="11"
                                                                                   Opacity="0.7"
                                                                                   Text="{Binding SiteName}"
                                                                                   TextWrapping="Wrap"
                                                                                   IsVisible="{Binding SiteName, Converter={StaticResource StringNotNullOrEmptyConverter}}"/>
                                                                        <TextBlock FontWeight="SemiBold"
                                                                                   TextWrapping="Wrap"
                                                                                   MaxHeight="44">
                                                                            <TextBlock.Text>
                                                                                <MultiBinding Converter="{StaticResource FirstNonEmptyStringConverter}">
                                                                                    <Binding Path="Title" />
                                                                                    <Binding Path="DisplayUrl" />
                                                                                    <Binding Path="Url" />
                                                                                </MultiBinding>
                                                                            </TextBlock.Text>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="12"
                                                                                   TextWrapping="Wrap"
                                                                                   Opacity="0.75"
                                                                                   MaxHeight="60"
                                                                                   Text="{Binding Description}"
                                                                                   IsVisible="{Binding Description, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                                                                        <TextBlock FontSize="12"
                                                                                   Foreground="{DynamicResource App.Accent}"
                                                                                   TextTrimming="CharacterEllipsis">
                                                                            <TextBlock.Text>
                                                                                <MultiBinding Converter="{StaticResource FirstNonEmptyStringConverter}">
                                                                                    <Binding Path="DisplayUrl" />
                                                                                    <Binding Path="Url" />
                                                                                </MultiBinding>
                                                                            </TextBlock.Text>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </Button.ContentTemplate>
                                                    </Button>
                                                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                            <TextBlock Classes="message-meta" FontSize="11" Opacity="0.55">
                                                                <TextBlock.IsVisible>
                                                                    <MultiBinding Converter="{StaticResource EditCountdownVisibleConverter}">
                                                                        <Binding />
                                                                        <Binding Path="$parent[v:MainWindow].DataContext" />
                                                                        <Binding Path="$parent[v:MainWindow].DataContext.UiTick" />
                                                                    </MultiBinding>
                                                                </TextBlock.IsVisible>
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource EditCountdownConverter}">
                                                                        <Binding />
                                                                        <Binding Path="$parent[v:MainWindow].DataContext" />
                                                                        <Binding Path="$parent[v:MainWindow].DataContext.UiTick" />
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <!-- Delivery status indicators removed -->
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.DataTemplates>
                        </ItemsControl>
                        <Border Grid.Row="1" x:Name="ChatEndAnchor" Height="1" Background="Transparent" Focusable="False"/>
                    </Grid>
                </ScrollViewer>

                <Button x:Name="JumpToBottomButton"
                        Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,12,12"
                        IsVisible="False"
                        Focusable="False"
                        Click="JumpToBottom_Click"
                        ToolTip.Tip="{Binding LocalizedJumpToPresent}">
                    <Border Background="#2B2B2B" CornerRadius="16" Padding="12,6" BorderBrush="#444" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Classes="icon-mdl2" Text="&#xE76C;"/>
                            <TextBlock x:Name="JumpToBottomLabel" Text="{Binding LocalizedJumpToPresent}"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Border Grid.Row="2" Padding="12" BorderBrush="{DynamicResource App.Border}" BorderThickness="1 1 0 0" Background="{DynamicResource App.Background}">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                            <Button Classes="icon-button" Click="BoldButton_Click" ToolTip.Tip="{Binding LocalizedBold}">
                                <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                            </Button>
                            <Button Classes="icon-button" Click="ItalicButton_Click" ToolTip.Tip="{Binding LocalizedItalic}">
                                <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                            </Button>
                            <Button Classes="icon-button" Click="UnderlineButton_Click" ToolTip.Tip="{Binding LocalizedUnderline}">
                                <TextBlock Text="U" TextDecorations="Underline" FontSize="13"/>
                            </Button>
                            <Button Classes="icon-button" Click="StrikeButton_Click" ToolTip.Tip="{Binding LocalizedStrikeThrough}">
                                <TextBlock Text="S" TextDecorations="Strikethrough" FontSize="13"/>
                            </Button>
                            <Button Classes="icon-button" Click="QuoteButton_Click" ToolTip.Tip="{Binding LocalizedQuote}">
                                <TextBlock Text="&gt;" FontSize="13"/>
                            </Button>
                            <Button Classes="icon-button" Click="CodeButton_Click" ToolTip.Tip="{Binding LocalizedCode}">
                                <TextBlock Text="&lt;/&gt;" FontFamily="Consolas" FontSize="11"/>
                            </Button>
                            <Button Classes="icon-button" Click="SpoilerButton_Click" ToolTip.Tip="{Binding LocalizedSpoiler}">
                                <TextBlock Text="||" FontSize="13"/>
                            </Button>
                        </StackPanel>
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Image Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center" ToolTip.Tip="{Binding LocalizedChatEncrypted}" IsVisible="{Binding IsChatEncrypted}" Source="{DynamicResource Icon.Encrypted}"/>
                            <TextBox Grid.Column="1"
                                     x:Name="MessageInput"
                                     Classes="chat-input"
                                     Text="{Binding OutgoingMessage, Mode=TwoWay}"
                                     Watermark="{Binding LocalizedTypeMessage}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="56"
                                     MaxHeight="200"
                                     VerticalAlignment="Center"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     TextChanged="MessageInput_TextChanged"/>
                            <Button Grid.Column="2" Classes="icon-button" Margin="8 0 0 0" Command="{Binding SendCommand}" ToolTip.Tip="{Binding LocalizedSendMessage}">
                                <TextBlock Classes="icon-mdl2" Text="&#xE724;"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- Floating Markdown Toolbar (Discord-style, shows on text selection) -->
                <Popup x:Name="MarkdownToolbarPopup"
                       PlacementTarget="{Binding #MessageInput}"
                       Placement="Top"
                       VerticalOffset="-8"
                       IsLightDismissEnabled="False"
                       IsOpen="False">
                    <c:MarkdownToolbar x:Name="MarkdownFloatingToolbar"
                                       TargetTextBox="{Binding #MessageInput}"/>
                </Popup>
            </Grid>
            <!-- Right-side Notification Center panel -->
            <Border x:Name="RightPanelRoot" Grid.Column="5" Padding="8" Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" MinWidth="220" IsVisible="False">
                <Grid RowDefinitions="Auto,Auto,*">
                    <!-- Header: arrows + title + toolbar actions -->
                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button x:Name="NotifPrevBtn" Classes="icon-button" ToolTip.Tip="{Binding LocalizedPrevious}" Width="28" Height="28">
                                <TextBlock Classes="icon-mdl2" Text="&#xE100;"/>
                            </Button>
                            <Button x:Name="NotifNextBtn" Classes="icon-button" ToolTip.Tip="{Binding LocalizedNext}" Width="28" Height="28">
                                <TextBlock Classes="icon-mdl2" Text="&#xE101;"/>
                            </Button>
                        </StackPanel>
                        <TextBlock x:Name="NotificationsTitle" Grid.Column="1" Text="{Binding LocalizedPendingInvites}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button x:Name="RejectAllInvitesBtn" Classes="icon-button" ToolTip.Tip="{Binding LocalizedClearInvites}" IsVisible="True">
                                <TextBlock Classes="icon-mdl2" Text="&#xE74D;"/>
                            </Button>
                            <Button x:Name="MarkAllMessagesBtn" Classes="icon-button" ToolTip.Tip="{Binding LocalizedMarkAllRead}" IsVisible="True">
                                <TextBlock Classes="icon-mdl2" Text="&#xE8C3;"/>
                            </Button>
                            <Button x:Name="ClearAllAlertsBtn" Classes="icon-button" ToolTip.Tip="{Binding LocalizedClearAllAlerts}" IsVisible="False">
                                <TextBlock Classes="icon-mdl2" Text="&#xE74D;"/>
                            </Button>
                            <Button x:Name="CloseNotificationsBtn" Classes="icon-button" ToolTip.Tip="{Binding LocalizedClose}" Click="ToggleRightPanel_Click">
                                <TextBlock Classes="icon-mdl2" Text="&#xE711;"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Tab-like content hosts (we'll use simple visibility switching via code-behind) -->
                    <ScrollViewer x:Name="InvitesHost" Grid.Row="2" VerticalScrollBarVisibility="Auto" IsVisible="True">
                        <StackPanel x:Name="InvitesStack" Margin="4" Spacing="6" />
                    </ScrollViewer>
                    <ScrollViewer x:Name="MessagesHost" Grid.Row="2" VerticalScrollBarVisibility="Auto" IsVisible="False">
                        <StackPanel x:Name="MessagesStack" Margin="4" Spacing="6" />
                    </ScrollViewer>
                    <ScrollViewer x:Name="AlertsHost" Grid.Row="2" VerticalScrollBarVisibility="Auto" IsVisible="False">
                        <StackPanel x:Name="AlertsStack" Margin="4" Spacing="6" />
                    </ScrollViewer>
                </Grid>
            </Border>
            <!-- Slide-in invite toast (top-right) -->
            <!-- Close BodyGrid before overlays to keep hierarchy balanced -->
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBar.Background}" BorderBrush="{DynamicResource App.Border}" BorderThickness="0,1,0,0" Padding="6,3" Height="26">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Left: Connected peers count -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="&#xE77B;" Classes="icon-mdl2" FontSize="12" Foreground="{DynamicResource StatusBar.Foreground}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ConnectedPeerCountDisplay}" FontSize="12" Foreground="{DynamicResource StatusBar.Foreground}" VerticalAlignment="Center" FontWeight="Medium"/>
                    <TextBlock Text="{Binding LocalizedConnectedPeers}" FontSize="11" Foreground="{DynamicResource StatusBar.ForegroundSecondary}" VerticalAlignment="Center" Opacity="0.8"/>
                </StackPanel>

                <!-- Right: Streamer mode indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" IsVisible="{Binding StreamerModeBadgeVisible}">
                    <Border Background="{DynamicResource StatusBar.StreamerBadge}" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="{Binding LocalizedStreamerModeActive}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource StatusBar.StreamerBadgeForeground}" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Full Profile Overlay marker below remains unchanged -->
            <!-- Full Profile Overlay -->
        <Grid Grid.RowSpan="3" ZIndex="1000" IsVisible="{Binding IsFullProfileOpen}">
            <!-- Backdrop: darken main window and allow click-to-dismiss -->
            <Border x:Name="FullProfileBackdrop" Background="#99000000" PointerPressed="FullProfileBackdrop_PointerPressed"/>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16" CornerRadius="10"
                    Background="{DynamicResource App.Surface}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1"
                    PointerPressed="FullProfileContent_PointerPressed">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12" MinWidth="480" MaxWidth="540">
                    <!-- Header with Avatar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="28" Background="{DynamicResource App.Background}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1">
                            <Grid>
                                <TextBlock Classes="icon-mdl2" Text="&#xE77B;" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                                <c:AvatarImage Classes="avatar-img" Stretch="UniformToFill">
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource UidToAvatarConverter}">
                                            <Binding Path="SelectedContact.UID" />
                                            <Binding Path="AvatarVersion" />
                                        </MultiBinding>
                                    </Image.Source>
                                </c:AvatarImage>
                                <!-- Presence overlay on profile avatar -->
                                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="20" Height="20" CornerRadius="10"
                                        Background="{DynamicResource App.Background}"
                                        BorderBrush="{DynamicResource App.Border}" BorderThickness="1">
                                    <Grid>
                                        <Ellipse Width="12" Height="12" Fill="#22CC66" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding SelectedContact.Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=Online}"/>
                                        <Image Width="12" Height="12" Source="avares://Zer0Talk/Assets/Icons/Status/Away.ico" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding SelectedContact.Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=Idle}"/>
                                        <Image Width="12" Height="12" Source="avares://Zer0Talk/Assets/Icons/Status/DND.ico" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding SelectedContact.Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=DoNotDisturb}"/>
                                        <Ellipse Width="12" Height="12" Stroke="#888" StrokeThickness="1.6" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="Transparent" IsVisible="{Binding SelectedContact.Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=Invisible}"/>
                                        <Ellipse Width="12" Height="12" Fill="Transparent" Stroke="#888888" StrokeThickness="1.8" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding SelectedContact.Presence, Converter={StaticResource PresenceEqualsToBoolConverter}, ConverterParameter=Offline}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock FontSize="16" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                        <Binding Path="SelectedContact.DisplayName"/>
                                        <Binding Path="IsStreamerMode"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <!-- Verification shield in profile card -->
                                <c:VerifiedBadge Width="16" Height="16" VerticalAlignment="Center">
                                    <c:VerifiedBadge.IsVisible>
                                        <MultiBinding Converter="{StaticResource VerificationShieldVisibilityConverter}">
                                            <Binding Path="SelectedContact.PublicKeyVerified"/>
                                            <Binding Path="SelectedContact.IsVerified"/>
                                            <Binding Path="SelectedContact.IsSimulated"/>
                                        </MultiBinding>
                                    </c:VerifiedBadge.IsVisible>
                                </c:VerifiedBadge>
                                <Border Background="#DA7C19" CornerRadius="4" Padding="4,1" IsVisible="{Binding SelectedContact.IsSimulated}">
                                    <TextBlock Text="{Binding $parent[v:MainWindow].DataContext.LocalizedSimulated}" Foreground="White" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Profile Card (matching user profile layout) -->
                    <Border Grid.Row="1" Background="{DynamicResource App.CardBackground}" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="16">
                            <!-- Identity Section -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding $parent[v:MainWindow].DataContext.LocalizedIdentityLabel}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding $parent[v:MainWindow].DataContext.LocalizedDisplayNameLabel}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                                <Binding Path="SelectedContact.DisplayName"/>
                                                <Binding Path="$parent[v:MainWindow].DataContext.IsStreamerMode"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding $parent[v:MainWindow].DataContext.LocalizedUidLabel}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource StreamerModeNameConverter}">
                                                    <Binding Path="SelectedContact.DisplayUID"/>
                                                    <Binding Path="$parent[v:MainWindow].DataContext.IsStreamerMode"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Button Click="CopyContactUid_Click" CommandParameter="{Binding SelectedContact.UID}" ToolTip.Tip="{Binding $parent[v:MainWindow].DataContext.LocalizedCopyUID}" Padding="6,2" MinWidth="0">
                                            <TextBlock Classes="icon-mdl2" Text="&#xE8C8;"/>
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding $parent[v:MainWindow].DataContext.LocalizedPresenceLabel}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedContact.Presence, Converter={StaticResource PresenceToDisplayStringConverter}}" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding $parent[v:MainWindow].DataContext.LocalizedPrevName}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <ComboBox ItemsSource="{Binding SelectedContact.DisplayNameHistory}" SelectedItem="{Binding SelectedContactPreviousName}" Width="220">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Border BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="12" Padding="8,2">
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} {1}">
                                                        <Binding Path="$parent[v:MainWindow].DataContext.LocalizedChanges"/>
                                                        <Binding Path="SelectedContact.DisplayNameChangeCount"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- Public Key row, visible only when enabled in General -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding $parent[v:MainWindow].DataContext.LocalizedPublicKeyLabel}" VerticalAlignment="Center" IsVisible="{Binding ShowPublicKeys}"/>
                                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowPublicKeys}">
                                        <TextBlock Text="{Binding SelectedContactPublicKeyHex}" TextTrimming="CharacterEllipsis" Width="240" FontFamily="Consolas"/>
                                        <Button Click="CopySelectedContactKey_Click" ToolTip.Tip="{Binding $parent[v:MainWindow].DataContext.LocalizedCopyPublicKey}" Padding="6,2" MinWidth="0">
                                            <TextBlock Classes="icon-mdl2" Text="&#xE8C8;"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Separator -->
                            <Border BorderBrush="{DynamicResource App.Border}" BorderThickness="0,1,0,0"/>

                            <!-- About Section -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding $parent[v:MainWindow].DataContext.LocalizedAbout}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="12">
                                    <TextBlock Grid.Column="0" Text="{Binding $parent[v:MainWindow].DataContext.LocalizedBioLabel}" VerticalAlignment="Top"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedContact.Bio}" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Editable display name for simulated contacts only -->
                    <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsSelectedContactSimulated}">
                        <TextBlock Text="{Binding $parent[v:MainWindow].DataContext.LocalizedDisplayNameLabel}"/>
                        <TextBox Text="{Binding EditableDisplayName, Mode=TwoWay}"/>
                        <Button Content="{Binding LocalizedSaveSimulated}" Command="{Binding SaveSimulatedProfileCommand}" HorizontalAlignment="Left"/>
                        <!-- Debug-only container: controls are injected at runtime in DEBUG builds -->
                        <StackPanel x:Name="DebugSimulatedProfilePanel" Orientation="Horizontal" Spacing="8" IsVisible="False">
                            <TextBlock Text="Debug:" VerticalAlignment="Center"/>
                            <!-- Buttons/toggles inserted via code-behind in DEBUG builds -->
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="{Binding LocalizedVerify}" Click="StartVerification_Click">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource NotOrConverter}">
                                    <Binding Path="SelectedContact.IsVerified"/>
                                    <Binding Path="SelectedContact.PublicKeyVerified"/>
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                        <Button Content="{Binding LocalizedClose}" Command="{Binding CloseFullProfileCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Settings overlay: full-panel takeover (Discord-style) -->
        <Grid x:Name="SettingsOverlay"
              Grid.RowSpan="3"
              ZIndex="1200"
              IsVisible="False"
              Background="{DynamicResource App.Background}"
              KeyDown="SettingsOverlay_KeyDown">
            <Grid RowDefinitions="Auto,*">
                <!-- Header bar (same color as app; draggable) -->
                <Border Grid.Row="0"
                        Background="{DynamicResource App.Background}"
                        BorderBrush="{DynamicResource App.Border}"
                        BorderThickness="0 0 0 1"
                        Padding="12,8"
                        PointerPressed="DragBar_PointerPressed">
                    <TextBlock Text="{Binding LocalizedSettings}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Border>
                <!-- Main settings content + floating controls/notifications -->
                <Grid Grid.Row="1">
                    <!-- Content host -->
                    <ContentControl x:Name="InlineSettingsHost"/>
                    <!-- Floating icon buttons (top-right), consistent with app button metrics -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0">
                        <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedSave}" Click="SettingsOverlay_Save_Click">
                            <TextBlock Classes="icon-mdl2" Text="&#xE74E;"/>
                        </Button>
                        <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedCloseEsc}" Click="SettingsOverlay_Close_Click">
                            <TextBlock Classes="icon-mdl2" Text="&#xE711;"/>
                        </Button>
                    </StackPanel>
                    
                </Grid>
            </Grid>
        </Grid>

        <!-- Lock overlay: darken the main UI while the Unlock dialog is active -->
        <Border x:Name="LockOverlay" Grid.RowSpan="3" ZIndex="2000" IsVisible="False" Background="#99000000" IsHitTestVisible="True" Opacity="0.0">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Border.Transitions>
        </Border>
    </Grid>
</Window>

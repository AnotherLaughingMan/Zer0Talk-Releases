<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Zer0Talk.ViewModels"
        x:Class="Zer0Talk.Views.LogViewerWindow"
        x:DataType="vm:LogViewerViewModel"
        mc:Ignorable="d"
        Title="{Binding LocalizedTitle}"
        Width="960"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="32"
        Background="{DynamicResource App.Background}">
    <Window.DataContext>
        <vm:LogViewerViewModel />
    </Window.DataContext>

    <Window.Styles>
        <!-- ListBox item style for log files -->
        <Style Selector="ListBox.log-list-box">
            <Setter Property="Background" Value="{DynamicResource App.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
        
        <Style Selector="ListBox.log-list-box ListBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
        </Style>
        
        <Style Selector="ListBox.log-list-box ListBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource App.SurfaceHover}"/>
        </Style>
        
        <Style Selector="ListBox.log-list-box ListBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource App.AccentBackground}"/>
        </Style>
        
        <Style Selector="ListBox.log-list-box ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource App.AccentBackgroundHover}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource App.Background}">
        <Border Grid.Row="0"
                Padding="8,6"
                BorderBrush="{DynamicResource App.Border}"
                BorderThickness="0 0 0 1"
                Background="{DynamicResource App.TitleBarBackground}"
                PointerPressed="DragBar_PointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0"
                           Classes="icon-mdl2"
                           Text="&#xE8A5;"
                           FontSize="18"
                           Foreground="{DynamicResource App.TitleBarForeground}"
                           Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding LocalizedTitle}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource App.TitleBarForeground}"/>
                <Button Grid.Column="2"
                        Classes="icon-button"
                        ToolTip.Tip="Minimize"
                        Click="Minimize_Click">
                    <TextBlock Classes="icon-mdl2" Text="&#xE921;"/>
                </Button>
                <Button Grid.Column="3"
                        Classes="icon-button"
                        ToolTip.Tip="Close"
                        Click="Close_Click">
                    <TextBlock Classes="icon-mdl2" Text="&#xE8BB;"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource App.Background}">
            <Grid Margin="12" RowDefinitions="Auto,*" RowSpacing="10">
                <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="6">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="Logs directory" FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="{Binding CurrentDirectory}"
                                       Classes="app-trunc"
                                       ToolTip.Tip="{Binding CurrentDirectory}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="{Binding LocalizedRefresh}" Command="{Binding RefreshCommand}" MinWidth="90" ToolTip.Tip="Rescan the logs directory"/>
                        <Button Grid.Column="2" Content="{Binding LocalizedReload}" Command="{Binding ReloadCommand}" MinWidth="90" ToolTip.Tip="Reload the currently selected log"/>
                        <Button Grid.Column="3" Content="{Binding LocalizedTrim}" Command="{Binding TrimSelectedCommand}" MinWidth="100" ToolTip.Tip="Apply debug maintenance settings to trim this log file" Background="{DynamicResource App.Warning}" Foreground="White"/>
                        <Button Grid.Column="4" Content="{Binding LocalizedCopyPath}" Command="{Binding CopyPathCommand}" MinWidth="90" ToolTip.Tip="Copy the selected log's full path"/>
                        <Button Grid.Column="5" Content="{Binding LocalizedOpenFolder}" Command="{Binding OpenFolderCommand}" MinWidth="100" ToolTip.Tip="Open the logs folder in your file explorer"/>
                        <ToggleSwitch Grid.Column="6"
                                      Content="Autoscroll"
                                      IsChecked="{Binding AutoscrollEnabled}"
                                      VerticalAlignment="Center"
                                      MinWidth="110"
                                      ToolTip.Tip="Keep the view pinned to the latest log entries"/>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource App.ForegroundSecondary}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <!-- Two-column layout: List on left, Content on right -->
                    <Grid ColumnDefinitions="260,*">
                        <!-- Left side: Log file list -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource App.Surface}"
                                BorderBrush="{DynamicResource App.Border}"
                                BorderThickness="0,0,1,0">
                            <ListBox x:Name="LogListBox"
                                     ItemsSource="{Binding Tabs}"
                                     SelectedItem="{Binding SelectedTab}"
                                     Classes="log-list-box"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LogDocumentViewModel">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource App.ForegroundPrimary}"/>
                                            <TextBlock Text="{Binding Info}"
                                                       FontSize="11"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource App.ForegroundSecondary}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        
                        <!-- Right side: Selected log content -->
                        <ContentControl Grid.Column="1"
                                        Content="{Binding SelectedTab}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate x:DataType="vm:LogDocumentViewModel">
                                    <Border Background="#101010" BorderThickness="0">
                                        <Grid RowDefinitions="Auto,*">
                                            <Border Grid.Row="0"
                                                    Padding="14,10"
                                                    Background="#151515"
                                                    BorderBrush="#202020"
                                                    BorderThickness="0 0 0 1">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="#E0E0E0"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Info}"
                                                               Foreground="#B0B0B0"
                                                               FontSize="12"/>
                                                    <TextBlock Text="Loading..."
                                                               Foreground="#E0E0E0"
                                                               FontSize="12"
                                                               IsVisible="{Binding IsLoading}"/>
                                                </StackPanel>
                                            </Border>
                                            <ScrollViewer x:Name="LogContentScroll"
                                                          Grid.Row="1"
                                                          Background="#101010"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto">
                                                <TextBlock Text="{Binding Content}"
                                                           Foreground="#D8D8D8"
                                                           FontFamily="Consolas"
                                                           FontSize="13"
                                                           TextWrapping="NoWrap"/>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Grid>
                    
                    <!-- Empty state overlay -->
                    <Border Background="#AA000000"
                            CornerRadius="6"
                            Padding="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding HasTabs, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="No log files found" Foreground="{DynamicResource App.ForegroundPrimary}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Use Refresh to re-scan the logs directory." Foreground="{DynamicResource App.ForegroundSecondary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

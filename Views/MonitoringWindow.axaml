<!--
    MonitoringWindow: standalone live monitoring UI.
    - User-configurable refresh interval (250ms .. 20m) persisted in AppSettings.MonitoringIntervalMs.
    - Real-time traffic counters, port bindings, NAT status with indicator + legend, scrollable log.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Zer0Talk.ViewModels"
    xmlns:vc="clr-namespace:Zer0Talk.Views.Controls"
        x:Class="Zer0Talk.Views.MonitoringWindow"
    x:Name="MonitoringWin"
    Title="{Binding LocalizedTitle}"
    Width="700" Height="520"
    MinWidth="640" MinHeight="440"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="36"
    mc:Ignorable="d"
        x:DataType="vm:MonitoringViewModel"
        Background="{DynamicResource App.Background}">
    <Window.DataContext>
        <vm:MonitoringViewModel />
    </Window.DataContext>

    <!-- [CHROME] Custom client area; drag bar matching MainWindow style -->
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Padding="6" BorderBrush="{DynamicResource App.Border}" BorderThickness="0 0 0 1" Background="{DynamicResource App.TitleBarBackground}"
                PointerPressed="DragBar_PointerPressed">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Monitoring" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource App.TitleBarForeground}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LocalizedViewMode}" VerticalAlignment="Center"/>
                    <ComboBox Width="120" SelectedIndex="{Binding ViewModeIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="{Binding LocalizedViewSummary}"/>
                        <ComboBoxItem Content="{Binding LocalizedViewNetwork}"/>
                        <ComboBoxItem Content="{Binding LocalizedViewAdvanced}"/>
                    </ComboBox>
                    <TextBlock Text="{Binding LocalizedRefresh}" VerticalAlignment="Center"/>
                    <ComboBox Width="96" SelectedIndex="{Binding IntervalIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="Real-Time"/>
                        <ComboBoxItem Content="500ms"/>
                        <ComboBoxItem Content="1s"/>
                        <ComboBoxItem Content="2s"/>
                        <ComboBoxItem Content="5s"/>
                        <ComboBoxItem Content="10s"/>
                        <ComboBoxItem Content="30s"/>
                        <ComboBoxItem Content="1m"/>
                        <ComboBoxItem Content="2m"/>
                        <ComboBoxItem Content="5m"/>
                        <ComboBoxItem Content="10m"/>
                        <ComboBoxItem Content="20m"/>
                    </ComboBox>
                    <TextBlock Text="{Binding LocalizedGraphStyle}" VerticalAlignment="Center"/>
                    <ComboBox Width="120" SelectedIndex="{Binding GraphStyleIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="{Binding LocalizedGraphLine}"/>
                        <ComboBoxItem Content="{Binding LocalizedGraphBar}"/>
                        <ComboBoxItem Content="{Binding LocalizedGraphShaded}"/>
                    </ComboBox>
                    <TextBlock Text="{Binding LocalizedLegendSide}" VerticalAlignment="Center"/>
                    <ComboBox Width="86" SelectedIndex="{Binding LegendPositionIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="{Binding LocalizedLegendLeft}"/>
                        <ComboBoxItem Content="{Binding LocalizedLegendRight}"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="icon-button" ToolTip.Tip="{Binding LocalizedRetryTooltip}" Command="{Binding RetryNatVerificationCommand}">
                        <TextBlock Classes="icon-mdl2" Text="&#xE72C;"/>
                    </Button>
                    <Button Classes="icon-button" ToolTip.Tip="Close" Command="{Binding CloseCommand}">
                        <TextBlock Classes="icon-mdl2" Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

    <!-- Body: Left sidebar + main content -->
    <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Navigation Rail -->
        <Border x:Name="NavRail" Grid.Column="0" BorderBrush="{DynamicResource App.Border}" BorderThickness="0 0 0 0" Background="{DynamicResource App.Surface}">
            <Border.Styles>
                <!-- Scope: only nav rail icon buttons -->
                <Style Selector="Button.icon-button">
                    <Setter Property="Width" Value="64"/>
                    <Setter Property="Height" Value="56"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="8,0"/>
                </Style>
            </Border.Styles>
            <Grid Margin="0,12" RowDefinitions="Auto,*,Auto">
                <!-- Primary action buttons at the top -->
                <StackPanel Grid.Row="0" Spacing="6" HorizontalAlignment="Center">
                    <Button Classes="icon-button" ToolTip.Tip="Restart Discovery - Resets the discovery process and attempts to reconnect to peers" Command="{Binding RestartDiscoveryCommand}">
                        <Grid Width="26" Height="26">
                            <Path Fill="{DynamicResource App.ForegroundPrimary}" Stretch="Uniform"
                                  Data="M15.5,14 C15.5,11.52 13.48,9.5 11,9.5 C9.94,9.5 8.97,9.88 8.19,10.52 L10,12.33 L4,13 L4.67,7 L6.41,8.74 C7.55,7.68 9.2,7 11,7 C14.86,7 18,10.14 18,14 C18,17.86 14.86,21 11,21 C8.87,21 6.96,20.02 5.7,18.48 L7.07,17.06 C7.95,18.14 9.38,19 11,19 C13.76,19 16,16.76 16,14 Z M11,11 L11,14.47 L13.21,16.68 L12.5,17.39 L9.75,14.64 L9.75,11 L11,11 Z"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Debug checkpoint controls at the bottom -->
                <StackPanel x:Name="DebugCheckpointStack" Grid.Row="2" Spacing="6" HorizontalAlignment="Center">
                    <!-- Debug buttons will be added programmatically in code-behind -->
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Vertical divider -->
        <Border Grid.Column="1" Background="{DynamicResource App.Border}" IsHitTestVisible="False"/>
        
    <!-- Compact container with consistent padding for a balanced UI -->
    <Border Grid.Column="2" Padding="10" Background="{DynamicResource App.Background}" BorderBrush="{DynamicResource App.Border}">
        <!-- Layout rows: header, controls, body(*) with chart + log, footer -->
        <!-- Layout polish: reduce row spacing a bit to fit comfortably in default window size -->
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="6">
            <!-- Header with NAT indicator and legend -->
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center" MinHeight="28">
                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <!-- Simplified NAT status with full details in tooltip -->
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LocalizedNAT}"/>
                        <Ellipse Width="10" Height="10" Fill="{Binding NatIndicatorBrush}" Opacity="{Binding NatIndicatorOpacity}"/>
                        <TextBlock Text="{Binding NatStatusShort}" ToolTip.Tip="{Binding NatStatus}"/>
                    </StackPanel>
                    <!-- [TRUNC-OPTIN] Summary can be lengthy; opt-in ellipsis + tooltip. -->
                    <TextBlock Classes="app-trunc" Text="{Binding DiagnosticsSummary}" FontSize="11" Opacity="0.85" TextTrimming="CharacterEllipsis"/>
                    <!-- Phase 4: Connection telemetry stats -->
                    <TextBlock Classes="app-trunc" Text="{Binding ConnectionStatsSummary}" FontSize="11" Opacity="0.85" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="Connection success rates: Direct/NAT/Relay attempts and UID mismatch count"/>
                    <TextBlock Classes="app-trunc" Text="{Binding RelayHealthSummary}" FontSize="10" Opacity="0.7" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="Relay server health: endpoint status, latency, and success rate"/>
                </StackPanel>
        <!-- Status Legend: fixed, theme-independent styling for consistency across all themes -->
        <!-- Layout tweak: slightly reduced padding to save vertical space without changing style -->
        <Border Grid.Column="1" Padding="6" Margin="8,0,0,0" CornerRadius="6"
                        BorderBrush="#4A4A4A" BorderThickness="1" Background="#2A2A2A">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding LocalizedStatusLegend}" FontWeight="SemiBold" Foreground="#EDEDED"/>
                        <!-- Two-column grid ensures perfect icon/label alignment without jitter -->
            <!-- Layout tweak: slightly reduce row spacing in legend for compactness -->
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="3" VerticalAlignment="Center">
                            <Ellipse Grid.Row="0" Grid.Column="0" Width="10" Height="10" Fill="#E0B000" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalizedSearching}" Foreground="#EDEDED" VerticalAlignment="Center"/>
                            <Ellipse Grid.Row="1" Grid.Column="0" Width="10" Height="10" Fill="#D24A4A" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LocalizedFailure}" Foreground="#EDEDED" VerticalAlignment="Center"/>
                            <Ellipse Grid.Row="2" Grid.Column="0" Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LocalizedSuccess}" Foreground="#EDEDED" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Controls row: traffic summary -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding LocalizedTrafficBytesPerSec}" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="{Binding TcpBrush}"/>
                        <TextBlock Text="{Binding TcpRate}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="{Binding UdpBrush}"/>
                        <TextBlock Text="{Binding UdpRate}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="{Binding OutBrush}"/>
                        <TextBlock Text="{Binding OutRate}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="#BF7BFF"/>
                        <TextBlock Text="{Binding RecvRate}"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="Transparent" IsHitTestVisible="False"/>
            </Grid>

            <!-- Body: ports line, NAT diagnostics, and traffic history chart -->
            <!-- Remove outer ScrollViewer to prevent window-level scrolling from interfering with log scrolling -->
            <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="{Binding LocalizedPorts}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TcpPortLabel}"/>
                        <TextBlock Text="{Binding UdpPortLabel}"/>
                        <TextBlock Text="{Binding ExternalPortLabel}"/>
                    </StackPanel>

                    <!-- NAT diagnostics details: compact two-column grid inside a styled border -->
                    <Border Grid.Row="1" Padding="8" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource App.Surface}" IsVisible="{Binding IsNetworkOrAdvancedMode}">
                        <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LocalizedGateway}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NatGateway}" Classes="app-trunc"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding LocalizedExternalIP}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding NatExternalIp}" Classes="app-trunc"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LocalizedService}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NatService}" Classes="app-trunc"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding LocalizedAltServices}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding NatAvailableServices}" Classes="app-trunc"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LocalizedMapPing}"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding LocalizedMapAt}"/>
                                <TextBlock Text="{Binding NatMapAttemptLabel}"/>
                                <TextBlock Text="{Binding LocalizedVerifyAt}"/>
                                <TextBlock Text="{Binding NatVerifyTimeLabel}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding LocalizedPunch}"/>
                            <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding NatPunchSummary}" ToolTip.Tip="{Binding NatPunchTooltip}"/>
                                <TextBlock Text="{Binding LocalizedHairpin}" ToolTip.Tip="{Binding HairpinTooltip}"/>
                                <TextBlock Text="{Binding HairpinStatus}" ToolTip.Tip="{Binding HairpinTooltip}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Discovery panel: tiny snapshot with restart control -->
                    <Border Grid.Row="2" Padding="8" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource App.Surface}" IsVisible="{Binding IsNetworkOrAdvancedMode}">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4" VerticalAlignment="Center">
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding LocalizedDiscovery}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DiscoveryState}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Text="{Binding LocalizedAttempts}"/>
                                <TextBlock Text="{Binding DiscoveryAttempts}"/>
                                <TextBlock Text="{Binding LocalizedBackoff}" Margin="12,0,0,0"/>
                                <TextBlock Text="{Binding DiscoveryBackoff}"/>
                                <TextBlock Text="s"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Text="{Binding LocalizedLastAttempt}"/>
                                <TextBlock Text="{Binding DiscoveryLastAttemptLabel}"/>
                                <TextBlock Text="{Binding LocalizedLastSuccess}"/>
                                <TextBlock Text="{Binding DiscoveryLastSuccessLabel}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" IsVisible="{Binding IsAdvancedMode}">
                                <TextBlock Text="{Binding LocalizedPresencePipeline}"/>
                                <TextBlock Text="{Binding PresencePipelineSummary}" Classes="app-trunc"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Persistent history chart using a lightweight drawing surface;
                         height constrained to ensure it fits the default window size -->
                    <Border Grid.Row="3" Padding="4" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource App.Surface}" ClipToBounds="True">
                        <!-- Chart uses fixed colors inside TrafficHistoryView to avoid theme bleed; only bind history -->
                        <!-- Chart can now expand vertically to fill remaining space -->
                        <vc:TrafficHistoryView History="{Binding History}" GraphStyleIndex="{Binding GraphStyleIndex}" LegendSide="{Binding LegendPositionIndex}" EnableRealtimeSmoothing="{Binding IsRealTimeRefresh}"/>
                    </Border>
                </Grid>

            <!-- Footer actions (logging controls removed) -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <!-- Close button moved to title bar top-right -->
            </StackPanel>
        </Grid>
    </Border>
    </Grid>
    </Grid>
</Window>
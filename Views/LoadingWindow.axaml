<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZTalk.ViewModels"
        x:Class="ZTalk.Views.LoadingWindow"
        x:DataType="vm:LoadingWindowViewModel"
        Title="ZTalk - Loading"
        Width="600"
        Height="400"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ShowInTaskbar="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="#1e1e1e">

    <Design.DataContext>
        <vm:LoadingWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <!-- Background gradient -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#2a2a2a" Offset="0"/>
                    <GradientStop Color="#1a1a1a" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        
        <!-- Main loading content -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="30">
            
            <!-- App Title/Logo area -->
            <TextBlock Text="ZTalk" 
                       FontSize="48" 
                       FontWeight="Bold" 
                       Foreground="#4a9eff" 
                       HorizontalAlignment="Center"/>
            
            <!-- Loading indicator -->
            <Border Width="80" Height="80" 
                    CornerRadius="40" 
                    BorderBrush="#4a9eff" 
                    BorderThickness="4"
                    HorizontalAlignment="Center">
                
                <!-- Inner loading dot -->
                <Ellipse Width="20" Height="20" 
                         Fill="#4a9eff" 
                         HorizontalAlignment="Left" 
                         VerticalAlignment="Top" 
                         Margin="10,10,0,0">
                    <Ellipse.Styles>
                        <Style Selector="Ellipse">
                            <Style.Animations>
                                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="Opacity" Value="1"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="50%">
                                        <Setter Property="Opacity" Value="0.3"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="Opacity" Value="1"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Ellipse.Styles>
                </Ellipse>
            </Border>
            
            <!-- Main status message -->
            <TextBlock Text="{Binding MainMessage}" 
                       FontSize="24" 
                       FontWeight="SemiBold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="500"/>
            
            <!-- Progress bar -->
            <ProgressBar Value="{Binding Progress}" 
                         Minimum="0" 
                         Maximum="100" 
                         Width="400" 
                         Height="8" 
                         Foreground="#4a9eff" 
                         Background="#333333"/>
            
            <!-- Current task/file being loaded -->
            <TextBlock Text="{Binding CurrentTask}" 
                       FontSize="14" 
                       Foreground="#cccccc" 
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="500"/>
            
            <!-- Loading steps list -->
            <ItemsControl ItemsSource="{Binding LoadingSteps}" 
                          MaxWidth="500">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="{Binding Icon}" 
                                       FontSize="12" 
                                       Foreground="{Binding StatusColor}" 
                                       Width="20"/>
                            <TextBlock Text="{Binding Description}" 
                                       FontSize="12" 
                                       Foreground="{Binding StatusColor}" 
                                       Margin="5,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
        </StackPanel>
        
        <!-- Version info in bottom corner -->
        <TextBlock Text="Initializing secure messaging system..." 
                   FontSize="10" 
                   Foreground="#666666" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom" 
                   Margin="0,0,0,20"/>
                   
    </Grid>
</Window>
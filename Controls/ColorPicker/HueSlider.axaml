<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zer0Talk.Controls.ColorPicker.HueSlider"
             Width="32" Height="240">
  <Grid>
    <!-- Hue gradient background (vertical rainbow) -->
    <Border x:Name="HueBar" CornerRadius="4" BorderThickness="1" BorderBrush="#555">
      <Border.Background>
        <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
          <GradientStop Color="#FFFF0000" Offset="0.0" />   <!-- Red -->
          <GradientStop Color="#FFFFFF00" Offset="0.17" />  <!-- Yellow -->
          <GradientStop Color="#FF00FF00" Offset="0.33" />  <!-- Green -->
          <GradientStop Color="#FF00FFFF" Offset="0.5" />   <!-- Cyan -->
          <GradientStop Color="#FF0000FF" Offset="0.67" />  <!-- Blue -->
          <GradientStop Color="#FFFF00FF" Offset="0.83" />  <!-- Magenta -->
          <GradientStop Color="#FFFF0000" Offset="1.0" />   <!-- Red -->
        </LinearGradientBrush>
      </Border.Background>
    </Border>
    
    <!-- Interactive canvas for thumb placement -->
    <Canvas x:Name="ThumbCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Border x:Name="Thumb" 
              Width="36" Height="10" 
              CornerRadius="2"
              BorderBrush="White" 
              BorderThickness="2"
              Background="#80000000"
              Canvas.Left="-2">
        <Border.Effect>
          <DropShadowEffect BlurRadius="3" Color="Black" Opacity="0.6" OffsetX="0" OffsetY="0"/>
        </Border.Effect>
      </Border>
    </Canvas>
  </Grid>
</UserControl>

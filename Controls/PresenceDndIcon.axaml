<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zer0Talk.Controls.PresenceDndIcon"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="12"
             Height="12">
  <Viewbox Stretch="Uniform">
    <Canvas Width="24" Height="24">
      <Ellipse Width="18" Height="18" Canvas.Left="3" Canvas.Top="3"
               Fill="{DynamicResource App.Error}"/>
      <Rectangle Width="12" Height="3" RadiusX="1.5" RadiusY="1.5"
                 Canvas.Left="6" Canvas.Top="10.5"
                 Fill="{DynamicResource App.OnError}"/>
    </Canvas>
  </Viewbox>
</UserControl>

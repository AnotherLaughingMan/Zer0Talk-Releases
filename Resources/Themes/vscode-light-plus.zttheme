{
  "id": "vscode-light-plus",
  "displayName": "VS Code Light+",
  "description": "VS Code-inspired light theme with clean contrast and blue highlights.",
  "author": "Zer0Talk",
  "version": "1.0.0",
  "baseVariant": "Light",
  "resourceDictionaries": [

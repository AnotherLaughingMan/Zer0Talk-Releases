{
  "id": "legacy-butter",
  "displayName": "Butter",
  "description": "Legacy Butter theme (compatibility mode)",
  "author": "Zer0Talk",
  "version": "1.0.0",
  "baseVariant": "Dark",
  "resourceDictionaries": [
    "avares://Zer0Talk/Styles/ButterThemeOverride.axaml"
  ],
  "colorOverrides": {
    "StatusBar.Background": "#18170F",

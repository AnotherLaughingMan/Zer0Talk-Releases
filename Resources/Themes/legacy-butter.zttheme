    "StatusBar.ForegroundSecondary": "#8A7F60",
    "StatusBar.StreamerBadge": "#D4A017",
    "StatusBar.StreamerBadgeForeground": "#1C1B18"
  },
  "gradients": {
    "App.TitleBarBackground": {
      "startColor": "#1C1B18",
      "endColor": "#1C1B18",
      "angle": 90
    }
  },
  "defaultFontFamily": null,
  "defaultUiScale": 1.0,
  "minAppVersion": null,
  "isLegacyTheme": true,
  "legacyThemeOption": 3,
  "allowsCustomization": false,
  "isReadOnly": true,
  "themeType": 0,
